# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sagrafacile
POSTGRES_PORT=5432

# Web Application Configuration
WEB_PORT=80
ASPNETCORE_ENVIRONMENT=Production

# Set to true to disable HTTPS redirect and HSTS.
# Required for HTTP-only LAN/offline deployments (see docker-compose.lan.yml).
AllowHttp=false

# JWT Authentication (override in production!)
Jwt__Key=SagraFacile-Super-Secret-Key-For-JWT-Authentication-2026!
Jwt__Issuer=SagraFacile
Jwt__Audience=SagraFacile

# Initial Admin Credentials (override in production!)
Seed__AdminUsername=admin
Seed__AdminPassword=Admin@123!
Seed__AdminEmail=admin@sagrafacile.local

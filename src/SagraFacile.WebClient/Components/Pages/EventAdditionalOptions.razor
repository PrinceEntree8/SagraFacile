@page "/events/{EventId:int}/options"
@attribute [Authorize(Roles = "Admin")]
@inject IEventService EventService
@inject IStringLocalizer<SharedResource> L

<PageTitle>@string.Format(L["EventOptions_PageTitle"], eventName)</PageTitle>

<div class="mb-3">
    <a href="/events" class="btn btn-outline-secondary btn-sm">@L["EventOptions_BackToEvents"]</a>
</div>

<h1>@L["EventOptions_Heading"]</h1>
@if (!string.IsNullOrEmpty(eventName))
{
    <p class="text-muted">@eventName</p>
}

@if (isLoading)
{
    <p><em>@L["EventOptions_Loading"]</em></p>
}
else if (notFound)
{
    <div class="alert alert-warning">@L["EventOptions_EventNotFound"]</div>
}
else
{
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(saveSuccess ? "alert-success" : "alert-danger")">@statusMessage</div>
    }

    <div class="row">
        <div class="col-md-7">

            <!-- Reservation Options -->
            <div class="card mb-4">
                <div class="card-header">
                    <h4 class="mb-0">@L["EventOptions_ReservationOptions"]</h4>
                </div>
                <div class="card-body">

                    <!-- Party Completion -->
                    <h5>@L["EventOptions_PartyCompletion"]</h5>
                    <p class="text-muted small">@L["EventOptions_PartyCompletionDesc"]</p>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="partyCompletionEnabled"
                               @bind="model.PartyCompletionEnabled" />
                        <label class="form-check-label" for="partyCompletionEnabled">
                            @L["EventOptions_EnablePartyCompletion"]
                        </label>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="minPartySize">@L["EventOptions_MinPartySize"]</label>
                        <input type="number" class="form-control" id="minPartySize" min="1"
                               @bind="model.MinPartySize" style="max-width: 120px;" />
                        <div class="form-text">@L["EventOptions_MinPartySizeDesc"]</div>
                    </div>

                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h4 class="mb-0">@L["EventOptions_ViewOptions"]</h4>
                </div>
                <div class="card-body">
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="showNotesField"
                               @bind="model.ShowNotesField" />
                        <label class="form-check-label" for="showNotesField">
                            @L["EventOptions_ShowNotesField"]
                        </label>
                        <div class="form-text">@L["EventOptions_ShowNotesFieldDesc"]</div>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="counterPeopleFirst"
                               @bind="model.CounterPeopleFirst" />
                        <label class="form-check-label" for="counterPeopleFirst">
                            @L["EventOptions_CounterPeopleFirst"]
                        </label>
                        <div class="form-text">@L["EventOptions_CounterPeopleFirstDesc"]</div>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="showCallCount"
                               @bind="model.ShowCallCount" />
                        <label class="form-check-label" for="showCallCount">
                            @L["EventOptions_ShowCallCount"]
                        </label>
                        <div class="form-text">@L["EventOptions_ShowCallCountDesc"]</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="maxWaitTimeMinutes">@L["EventOptions_MaxWaitTimeMinutes"]</label>
                        <input type="number" class="form-control" id="maxWaitTimeMinutes" min="1"
                               @bind="model.MaxWaitTimeMinutes" style="max-width: 120px;" />
                        <div class="form-text">@L["EventOptions_MaxWaitTimeMinutesDesc"]</div>
                    </div>
                </div>
            </div>

            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@isSaving">
                @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                @L["EventOptions_Save"]
            </button>

        </div>
    </div>
}

@code {
    [Parameter] public int EventId { get; set; }

    private string eventName = string.Empty;
    private bool isLoading = true;
    private bool notFound = false;
    private bool isSaving = false;
    private string statusMessage = string.Empty;
    private bool saveSuccess = false;

    private OptionsModel model = new();

    protected override async Task OnInitializedAsync()
    {
        var result = await EventService.GetEventOptionsAsync(EventId);
        if (result is null)
        {
            notFound = true;
        }
        else
        {
            model.PartyCompletionEnabled = result.IsPartyCompletionEnabled;
            model.MinPartySize = result.MinPartySize;
            model.ShowNotesField = result.ShowNotesField;
            model.CounterPeopleFirst = result.CounterPeopleFirst;
            model.ShowCallCount = result.ShowCallCount;
            model.MaxWaitTimeMinutes = result.MaxWaitTimeMinutes;

            var events = await EventService.GetEventsAsync();
            eventName = events.FirstOrDefault(e => e.Id == EventId)?.Name ?? string.Empty;
        }
        isLoading = false;
    }

    private async Task SaveAsync()
    {
        statusMessage = string.Empty;

        if (model.MinPartySize < 1)
        {
            statusMessage = L["EventOptions_MinPartySizeInvalid"];
            saveSuccess = false;
            return;
        }

        if (model.MaxWaitTimeMinutes < 1)
        {
            statusMessage = L["EventOptions_MaxWaitTimeMinutesInvalid"];
            saveSuccess = false;
            return;
        }

        isSaving = true;
        try
        {
            await EventService.UpdateEventOptionsAsync(EventId,
                new UpdateEventAdditionalOptionsRequest(
                    model.PartyCompletionEnabled,
                    model.MinPartySize,
                    model.ShowNotesField,
                    model.CounterPeopleFirst,
                    model.ShowCallCount,
                    model.MaxWaitTimeMinutes));

            statusMessage = L["EventOptions_Saved"];
            saveSuccess = true;
        }
        catch (Exception ex)
        {
            statusMessage = string.Format(L["EventOptions_Error"], ex.Message);
            saveSuccess = false;
        }
        isSaving = false;
    }

    private class OptionsModel
    {
        public bool PartyCompletionEnabled { get; set; } = false;
        public int MinPartySize { get; set; } = 8;
        public bool ShowNotesField { get; set; } = false;
        public bool CounterPeopleFirst { get; set; } = true;
        public bool ShowCallCount { get; set; } = false;
        public int MaxWaitTimeMinutes { get; set; } = 45;
    }
}

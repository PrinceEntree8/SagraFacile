@page "/menu"
@*@layout DisplayLayout*@
@using Microsoft.AspNetCore.SignalR.Client
@inject IStringLocalizer<SharedResource> L
@inject IMenuService MenuService
@inject IEventService EventService
@inject IReservationService ReservationService
@inject IJSRuntime JS

<PageTitle>@L["PublicMenu_PageTitle"]</PageTitle>

<div class="container py-4">
    @if (isLoading)
    {
        <p class="text-center"><em>@L["PublicMenu_Loading"]</em></p>
    }
    else if (activeEvent is null)
    {
        <div class="text-center text-muted mt-5">
            <h2>@L["PublicMenu_NoActiveEvent"]</h2>
        </div>
    }
    else
    {
        <div class="text-center mb-4">
            <h1>🍽️ @activeEvent.Name</h1>
        </div>

        <div class="text-center mb-4">
            <a class="btn btn-outline-primary btn-lg" href="/">
                @L["PublicMenu_GoToHome"]
            </a>
        </div>

        <section class="card mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">@L["PublicMenu_LatestCalled"]</h2>
                @if (initialLoadFailed)
                {
                    <div class="alert alert-warning mb-3" role="alert">
                        @L["NowCalling_LoadWarning"]
                    </div>
                }
                @if (latestCalled is null)
                {
                    <p class="text-muted mb-0">@L["PublicMenu_NoCalledYet"]</p>
                }
                else
                {
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="badge bg-primary fs-6">#@latestCalled.SequenceNumber</span>
                        <span class="fw-semibold">@latestCalled.CustomerName</span>
                        <span class="text-muted"><i class="bi bi-people"></i> @latestCalled.PartySize</span>
                    </div>
                }
            </div>
        </section>
        
        @if (!string.IsNullOrWhiteSpace(menuDetails?.WarningMessage))
        {
            <div class="alert alert-warning">@((MarkupString)menuDetails.WarningMessage)</div>
        }
        @if (!string.IsNullOrWhiteSpace(menuDetails?.Header))
        {
            <div class="menu-header mb-4">@((MarkupString)menuDetails.Header)</div>
        }

        @if (!items.Any())
        {
            <p class="text-center text-muted">@L["PublicMenu_NoItems"]</p>
        }
        else
        {
            @foreach (var catGroup in items
                .GroupBy(i => new { i.Id, i.Name })
                .OrderBy(g => categories.FirstOrDefault(c => c.Id == g.Key.Id)?.DisplayOrder ?? 999))
            {
                <section class="mb-5">
                    <h2 class="border-bottom pb-2">@catGroup.Key.Name</h2>
                    <div class="row row-cols-1 row-cols-md-2 g-3 mt-1">
                        @foreach (var item in catGroup.OrderBy(i => i.Name))
                        {
                            <div class="col">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <h5 class="card-title mb-1">@item.Name</h5>
                                            <span class="badge bg-primary fs-6 ms-2">
                                                @activeEvent.CurrencySymbol @((item.PriceCents / 100.0).ToString("0.00"))
                                            </span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            <p class="card-text text-muted small mb-2">@item.Description</p>
                                        }
                                        @if (item.Allergens.Any())
                                        {
                                            <div>
                                                <small class="text-muted">@L["PublicMenu_Allergens"]: </small>
                                                @foreach (var a in item.Allergens)
                                                {
                                                    <span class="badge bg-warning text-dark me-1" title="@L[$"Allergen_{a.Code}"]">
                                                        @a.Icon @a.Code
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }
        }
        @if (!string.IsNullOrWhiteSpace(menuDetails?.Footer))
        {
            <div class="menu-footer mt-4">@((MarkupString)menuDetails.Footer)</div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private EventDto? activeEvent;
    private IReadOnlyList<MenuItemDto> items = [];
    private IReadOnlyList<MenuCategoryDto> categories = [];
    private MenuDetailsDto? menuDetails;
    private CalledEntry? latestCalled;
    private HubConnection? hubConnection;
    private bool initialLoadFailed;
    private const string CalledStatus = "Called";

    protected override async Task OnInitializedAsync()
    {
        activeEvent = await EventService.GetActiveEventAsync();
        if (activeEvent is not null)
        {
            categories = await MenuService.GetCategoriesAsync(activeEvent.Id);
            items = await MenuService.GetMenuAsync(activeEvent.Id, includeUnavailable: false);
            menuDetails = await MenuService.GetMenuDetailsAsync(activeEvent.Id);
            
            await LoadLatestCalledAsync(activeEvent.Id);
        }
        isLoading = false;
    }

    private async Task LoadLatestCalledAsync(int eventId)
    {
        try
        {
            var result = await ReservationService.GetLastCalledReservationsAsync(eventId);
            var latest = result.FirstOrDefault();

            latestCalled = latest;
        }
        catch
        {
            initialLoadFailed = true;
        }
    }
    
    private DotNetObjectReference<PublicMenu>? _dotNetRef;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("visibilityHelpers.register", _dotNetRef);
        }
    }
    
    [JSInvokable("OnVisibilityChanged")]
    public async Task OnVisibilityChanged(bool visible)
    {
        if (visible && activeEvent is not null)
        {
            await LoadLatestCalledAsync(activeEvent.Id);
            await InvokeAsync(StateHasChanged);
        }
    }
    
    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        try { await JS.InvokeVoidAsync("visibilityHelpers.unregister"); }
        catch
        {
            // ignored
        }
    }
}

@page "/headwaiter"
@rendermode InteractiveServer
@using SagraFacile.Web.Features.Reservations
@using SagraFacile.Web.Infrastructure.CQRS
@using Microsoft.AspNetCore.SignalR.Client
@inject IMediator Mediator
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Head Waiter - Table Management</PageTitle>

<h1>Head Waiter - Table Management</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header">
                <h3>Update Table</h3>
            </div>
            <div class="card-body">
                <EditForm Model="@tableUpdate" OnValidSubmit="@UpdateTable">
                    <div class="mb-3">
                        <label class="form-label">Table Number</label>
                        <InputText @bind-Value="tableUpdate.TableNumber" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Cover Count</label>
                        <InputNumber @bind-Value="tableUpdate.CoverCount" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-primary" disabled="@isUpdating">
                        @if (isUpdating)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Update Table
                    </button>
                </EditForm>

                @if (!string.IsNullOrEmpty(updateMessage))
                {
                    <div class="alert alert-success mt-3">@updateMessage</div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3>Tables</h3>
            </div>
            <div class="card-body">
                @if (isLoadingTables)
                {
                    <p><em>Loading tables...</em></p>
                }
                else if (tables != null && tables.Any())
                {
                    <div class="list-group">
                        @foreach (var table in tables)
                        {
                            <div class="list-group-item @(selectedTable?.Id == table.Id ? "active" : "")" 
                                 @onclick="@(() => SelectTable(table))" style="cursor: pointer;">
                                <div class="d-flex w-100 justify-content-between">
                                    <h5 class="mb-1">Table @table.TableNumber</h5>
                                    <span class="badge @GetTableStatusBadge(table.Status)">@table.Status</span>
                                </div>
                                <p class="mb-1">Cover Count: <strong>@table.CoverCount</strong></p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p><em>No tables found.</em></p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h3>Best Fit Recommendations</h3>
                @if (selectedTable != null)
                {
                    <p class="mb-0">For Table @selectedTable.TableNumber (Covers: @selectedTable.CoverCount)</p>
                }
                else if (coverCountForSearch > 0)
                {
                    <p class="mb-0">For Cover Count: @coverCountForSearch</p>
                }
                else
                {
                    <p class="mb-0">All Called Reservations (FIFO Order)</p>
                }
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Cover Count</label>
                    <div class="input-group">
                        <InputNumber @bind-Value="coverCountForSearch" class="form-control" />
                        <button class="btn btn-outline-primary" @onclick="@SearchBestFit">Search Best Fit</button>
                    </div>
                </div>

                @if (isSearching)
                {
                    <p><em>Searching for best fit...</em></p>
                }
                else if (bestFitResults != null)
                {
                    @if (bestFitResults.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Match</th>
                                        <th>Queue #</th>
                                        <th>Name</th>
                                        <th>Party Size</th>
                                        <th>Notes</th>
                                        <th>Waiting</th>
                                        <th>Calls</th>
                                        <th>Last Call</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var match in bestFitResults)
                                    {
                                        <tr class="@GetMatchRowClass(match)">
                                            <td>
                                                <span class="badge @GetMatchBadge(match.MatchQuality)">
                                                    @match.MatchQuality
                                                </span>
                                            </td>
                                            <td><strong>@match.QueueNumber</strong></td>
                                            <td>@match.CustomerName</td>
                                            <td>
                                                <span class="badge bg-info">@match.PartySize</span>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(match.Notes))
                                                {
                                                    <span class="text-muted">@match.Notes</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>@FormatTimeSpan(match.WaitingTime)</td>
                                            <td>@match.CallCount</td>
                                            <td>
                                                @if (match.LastCalledAt.HasValue)
                                                {
                                                    @FormatTimeSpan(DateTime.UtcNow - match.LastCalledAt.Value)
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Never</span>
                                                }
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-primary" @onclick="@(() => SeatReservationAsync(match.Id))" disabled="@(actionInProgress == match.Id)">
                                                    Seat
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="alert alert-info mt-3">
                            <strong>Best Recommendation:</strong> Call <strong>@bestFitResults.First().QueueNumber</strong> - @bestFitResults.First().CustomerName (Party of @bestFitResults.First().PartySize)
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            No reservations match this table size.
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    private HubConnection? hubConnection;
    private TableUpdateModel tableUpdate = new();
    private List<GetTables.TableDto> tables = new();
    private GetTables.TableDto? selectedTable = null;
    private List<GetBestFitReservation.ReservationMatchDto> bestFitResults = new();
    private int coverCountForSearch = 4;
    private bool isLoadingTables = true;
    private bool isUpdating = false;
    private bool isSearching = false;
    private string updateMessage = string.Empty;
    private int? actionInProgress = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadTables();
        await LoadAllCalledReservations(); // Load all Called reservations by default
        await InitializeSignalR();
    }

    private async Task InitializeSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/reservations"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<int, string, int>("TableUpdated", async (id, tableNumber, coverCount) =>
        {
            await LoadTables();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string, string, int>("ReservationCreated", async (id, queueNumber, name, size) =>
        {
            if (coverCountForSearch > 0 || selectedTable != null)
            {
                await SearchBestFit();
            }
            else
            {
                await LoadAllCalledReservations(); // Refresh the default view
            }
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string, int>("ReservationCalled", async (id, queueNumber, callCount) =>
        {
            if (coverCountForSearch > 0 || selectedTable != null)
            {
                await SearchBestFit();
            }
            else
            {
                await LoadAllCalledReservations(); // Refresh the default view
            }
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string>("ReservationVoided", async (id, queueNumber) =>
        {
            if (coverCountForSearch > 0 || selectedTable != null)
            {
                await SearchBestFit();
            }
            else
            {
                await LoadAllCalledReservations(); // Refresh the default view
            }
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string>("ReservationSeated", async (id, queueNumber) =>
        {
            if (coverCountForSearch > 0 || selectedTable != null)
            {
                await SearchBestFit();
            }
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
    }

    private async Task LoadTables()
    {
        isLoadingTables = true;
        try
        {
            var query = new GetTables.Query();
            var result = await Mediator.Send(query, CancellationToken.None);
            tables = result.Tables;
        }
        finally
        {
            isLoadingTables = false;
        }
    }

    private async Task LoadAllCalledReservations()
    {
        isSearching = true;
        try
        {
            // Load all Called reservations without a specific cover count filter
            var query = new GetBestFitReservation.Query(0); // Use 0 to indicate "all"
            var result = await Mediator.Send(query, CancellationToken.None);
            bestFitResults = result.Matches.ToList();
        }
        finally
        {
            isSearching = false;
        }
    }

    private async Task UpdateTable()
    {
        isUpdating = true;
        updateMessage = string.Empty;

        try
        {
            var command = new UpdateTableCover.Command(
                null,
                tableUpdate.TableNumber,
                tableUpdate.CoverCount
            );

            var result = await Mediator.Send(command, CancellationToken.None);
            
            updateMessage = $"Table {result.TableNumber} updated successfully!";
            tableUpdate = new();
            
            // Notify via SignalR
            if (hubConnection?.State == HubConnectionState.Connected)
            {
                await hubConnection.SendAsync("NotifyTableUpdated", result.Id, result.TableNumber, result.CoverCount);
            }
            
            await LoadTables();
        }
        catch (Exception ex)
        {
            updateMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isUpdating = false;
        }
    }

    private async Task SelectTable(GetTables.TableDto table)
    {
        selectedTable = table;
        coverCountForSearch = table.CoverCount;
        await SearchBestFit();
    }

    private async Task SearchBestFit()
    {
        if (coverCountForSearch <= 0)
        {
            return;
        }

        isSearching = true;
        try
        {
            var query = new GetBestFitReservation.Query(coverCountForSearch);
            var result = await Mediator.Send(query, CancellationToken.None);
            bestFitResults = result.Matches;
        }
        finally
        {
            isSearching = false;
        }
    }

    private string GetTableStatusBadge(string status) => status switch
    {
        "Available" => "bg-success",
        "Occupied" => "bg-danger",
        "Reserved" => "bg-warning",
        _ => "bg-secondary"
    };

    private string GetMatchBadge(string matchQuality) => matchQuality switch
    {
        "Perfect" => "bg-success",
        "Good" => "bg-primary",
        "Acceptable" => "bg-info",
        _ => "bg-secondary"
    };

    private string GetMatchRowClass(GetBestFitReservation.ReservationMatchDto match)
    {
        if (match.MatchQuality == "Perfect")
            return "table-success";
        return "";
    }

    private string FormatTimeSpan(TimeSpan timeSpan)
    {
        if (timeSpan.TotalHours >= 1)
            return $"{(int)timeSpan.TotalHours}h {timeSpan.Minutes}m";
        return $"{(int)timeSpan.TotalMinutes}m";
    }

    private async Task SeatReservationAsync(int reservationId)
    {
        actionInProgress = reservationId;
        try
        {
            var command = new SeatReservation.Command(reservationId);
            await Mediator.Send(command, CancellationToken.None);
            
            // Notify via SignalR
            if (hubConnection?.State == HubConnectionState.Connected)
            {
                var match = bestFitResults.FirstOrDefault(r => r.Id == reservationId);
                if (match != null)
                {
                    await hubConnection.SendAsync("NotifyReservationSeated", reservationId, match.QueueNumber);
                }
            }
            
            // Refresh the best fit results
            if (coverCountForSearch > 0)
            {
                await SearchBestFit();
            }
        }
        catch (Exception ex)
        {
            updateMessage = $"Error seating reservation: {ex.Message}";
        }
        finally
        {
            actionInProgress = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private class TableUpdateModel
    {
        public string TableNumber { get; set; } = string.Empty;
        public int CoverCount { get; set; } = 4;
    }
}

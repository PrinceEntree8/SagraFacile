@page "/receptionist"
@rendermode InteractiveServer
@using SagraFacile.Web.Features.Reservations
@using SagraFacile.Web.Data
@using Microsoft.AspNetCore.SignalR.Client
@inject ApplicationDbContext DbContext
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Receptionist - Table Reservations</PageTitle>

<h1>Receptionist - Table Reservations</h1>

<div class="row">
    <div class="col-md-5">
        <div class="card mb-4">
            <div class="card-header">
                <h3>Create New Reservation</h3>
            </div>
            <div class="card-body">
                <EditForm Model="@newReservation" OnValidSubmit="@CreateReservation">
                    <div class="mb-3">
                        <label class="form-label">Customer Name</label>
                        <InputText @bind-Value="newReservation.CustomerName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Party Size</label>
                        <InputNumber @bind-Value="newReservation.PartySize" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Priority</label>
                        <InputNumber @bind-Value="newReservation.Priority" class="form-control" />
                        <small class="form-text text-muted">0 = normal, higher = higher priority</small>
                    </div>

                    <button type="submit" class="btn btn-primary" disabled="@isCreating">
                        @if (isCreating)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Create Reservation
                    </button>
                </EditForm>

                @if (!string.IsNullOrEmpty(creationMessage))
                {
                    <div class="alert alert-success mt-3">@creationMessage</div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3>Active Reservations</h3>
                <div>
                    <button class="btn btn-sm btn-outline-primary" @onclick="@(() => LoadReservations("Waiting"))">Waiting</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => LoadReservations("Called"))">Called</button>
                    <button class="btn btn-sm btn-outline-info" @onclick="@(() => LoadReservations(null))">All</button>
                </div>
            </div>
            <div class="card-body">
                @if (isLoading)
                {
                    <p><em>Loading reservations...</em></p>
                }
                else if (reservations != null && reservations.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Queue #</th>
                                    <th>Name</th>
                                    <th>Party</th>
                                    <th>Status</th>
                                    <th>Waiting</th>
                                    <th>Calls</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var reservation in reservations)
                                {
                                    <tr class="@GetRowClass(reservation)">
                                        <td><strong>@reservation.QueueNumber</strong></td>
                                        <td>@reservation.CustomerName</td>
                                        <td>
                                            <span class="badge bg-info">@reservation.PartySize</span>
                                            @if (reservation.Priority > 0)
                                            {
                                                <span class="badge bg-warning">P@reservation.Priority</span>
                                            }
                                        </td>
                                        <td><span class="badge @GetStatusBadge(reservation.Status)">@reservation.Status</span></td>
                                        <td>
                                            @FormatTimeSpan(reservation.WaitingTime)
                                            @if (reservation.TimeSinceLastCall.HasValue)
                                            {
                                                <br /><small class="text-muted">Last call: @FormatTimeSpan(reservation.TimeSinceLastCall.Value)</small>
                                            }
                                        </td>
                                        <td>@reservation.CallCount</td>
                                        <td>
                                            @if (reservation.Status == "Waiting" || reservation.Status == "Called")
                                            {
                                                <button class="btn btn-sm btn-success me-1" @onclick="@(() => CallReservationAsync(reservation.Id))" disabled="@(actionInProgress == reservation.Id)">
                                                    Call
                                                </button>
                                                <button class="btn btn-sm btn-danger" @onclick="@(() => VoidReservationAsync(reservation.Id))" disabled="@(actionInProgress == reservation.Id)">
                                                    Void
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="mt-3">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="card text-center">
                                    <div class="card-body">
                                        <h6 class="card-subtitle mb-2 text-muted">To Be Seated</h6>
                                        <h4 class="card-title">@toBeSeatedCount reservations</h4>
                                        <p class="text-muted">@toBeSeatedPeople people</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card text-center">
                                    <div class="card-body">
                                        <h6 class="card-subtitle mb-2 text-muted">Served</h6>
                                        <h4 class="card-title">@seatedCount reservations</h4>
                                        <p class="text-muted">@seatedPeople people</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card text-center bg-light">
                                    <div class="card-body">
                                        <h6 class="card-subtitle mb-2 text-muted">Total</h6>
                                        <h4 class="card-title">@totalCount reservations</h4>
                                        <p class="text-muted">@totalPeople people</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <p><em>No reservations found.</em></p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private HubConnection? hubConnection;
    private NewReservationModel newReservation = new();
    private List<GetReservations.ReservationDto> reservations = new();
    private int totalCount = 0;
    private int totalPeople = 0;
    private int toBeSeatedCount = 0;
    private int toBeSeatedPeople = 0;
    private int seatedCount = 0;
    private int seatedPeople = 0;
    private bool isLoading = true;
    private bool isCreating = false;
    private string creationMessage = string.Empty;
    private int? actionInProgress = null;
    private string? currentFilter = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadReservations(null);
        await InitializeSignalR();
    }

    private async Task InitializeSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/reservations"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<int, string, string, int>("ReservationCreated", async (id, queueNumber, name, size) =>
        {
            await LoadReservations(currentFilter);
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string, int>("ReservationCalled", async (id, queueNumber, callCount) =>
        {
            await LoadReservations(currentFilter);
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string>("ReservationVoided", async (id, queueNumber) =>
        {
            await LoadReservations(currentFilter);
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string>("ReservationSeated", async (id, queueNumber) =>
        {
            await LoadReservations(currentFilter);
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
    }

    private async Task LoadReservations(string? status)
    {
        isLoading = true;
        currentFilter = status;
        try
        {
            var query = new GetReservations.Query(Status: status, Page: 1, PageSize: 100);
            var result = await GetReservations.Handle(query, DbContext, CancellationToken.None);
            reservations = result.Reservations;
            totalCount = result.TotalCount;
            totalPeople = reservations.Sum(r => r.PartySize);
            
            // Calculate breakdown by status
            var toBeSeated = reservations.Where(r => r.Status == "Waiting" || r.Status == "Called").ToList();
            toBeSeatedCount = toBeSeated.Count;
            toBeSeatedPeople = toBeSeated.Sum(r => r.PartySize);
            
            var seated = reservations.Where(r => r.Status == "Seated").ToList();
            seatedCount = seated.Count;
            seatedPeople = seated.Sum(r => r.PartySize);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateReservation()
    {
        isCreating = true;
        creationMessage = string.Empty;

        try
        {
            var command = new CreateReservation.Command(
                newReservation.CustomerName,
                newReservation.PartySize,
                newReservation.Priority
            );

            var result = await Features.Reservations.CreateReservation.Handle(command, DbContext, CancellationToken.None);
            
            creationMessage = $"Reservation {result.QueueNumber} created successfully!";
            newReservation = new();
            
            // Notify via SignalR
            if (hubConnection?.State == HubConnectionState.Connected)
            {
                await hubConnection.SendAsync("NotifyReservationCreated", result.Id, result.QueueNumber, command.CustomerName, command.PartySize);
            }
            
            await LoadReservations(currentFilter);
        }
        catch (Exception ex)
        {
            creationMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isCreating = false;
        }
    }

    private async Task CallReservationAsync(int reservationId)
    {
        actionInProgress = reservationId;
        try
        {
            var command = new CallReservation.Command(reservationId, "Receptionist");
            var result = await CallReservation.Handle(command, DbContext, CancellationToken.None);
            
            if (result.Success)
            {
                var reservation = reservations.FirstOrDefault(r => r.Id == reservationId);
                if (reservation != null && hubConnection?.State == HubConnectionState.Connected)
                {
                    await hubConnection.SendAsync("NotifyReservationCalled", reservationId, reservation.QueueNumber, reservation.CallCount + 1);
                }
            }
            
            await LoadReservations(currentFilter);
        }
        finally
        {
            actionInProgress = null;
        }
    }

    private async Task SeatReservationAsync(int reservationId)
    {
        actionInProgress = reservationId;
        try
        {
            var command = new SeatReservation.Command(reservationId);
            var result = await SeatReservation.Handle(command, DbContext, CancellationToken.None);
            
            if (result.Success)
            {
                var reservation = reservations.FirstOrDefault(r => r.Id == reservationId);
                if (reservation != null && hubConnection?.State == HubConnectionState.Connected)
                {
                    await hubConnection.SendAsync("NotifyReservationSeated", reservationId, reservation.QueueNumber);
                }
            }
            
            await LoadReservations(currentFilter);
        }
        finally
        {
            actionInProgress = null;
        }
    }

    private async Task VoidReservationAsync(int reservationId)
    {
        actionInProgress = reservationId;
        try
        {
            var command = new VoidReservation.Command(reservationId);
            var result = await VoidReservation.Handle(command, DbContext, CancellationToken.None);
            
            if (result.Success)
            {
                var reservation = reservations.FirstOrDefault(r => r.Id == reservationId);
                if (reservation != null && hubConnection?.State == HubConnectionState.Connected)
                {
                    await hubConnection.SendAsync("NotifyReservationVoided", reservationId, reservation.QueueNumber);
                }
            }
            
            await LoadReservations(currentFilter);
        }
        finally
        {
            actionInProgress = null;
        }
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Waiting" => "bg-warning",
        "Called" => "bg-info",
        "Seated" => "bg-success",
        "Voided" => "bg-secondary",
        _ => "bg-secondary"
    };

    private string GetRowClass(GetReservations.ReservationDto reservation)
    {
        if (reservation.Priority > 0)
            return "table-warning";
        if (reservation.WaitingTime.TotalMinutes > 30)
            return "table-danger";
        return "";
    }

    private string FormatTimeSpan(TimeSpan timeSpan)
    {
        if (timeSpan.TotalHours >= 1)
            return $"{(int)timeSpan.TotalHours}h {timeSpan.Minutes}m";
        return $"{(int)timeSpan.TotalMinutes}m";
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private class NewReservationModel
    {
        public string CustomerName { get; set; } = string.Empty;
        public int PartySize { get; set; } = 2;
        public int Priority { get; set; } = 0;
    }
}

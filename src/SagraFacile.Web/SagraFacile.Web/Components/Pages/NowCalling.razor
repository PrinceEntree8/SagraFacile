@page "/nowcalling"
@using SagraFacile.Web.Features.Reservations
@using SagraFacile.Web.Data
@using Microsoft.AspNetCore.SignalR.Client
@inject ApplicationDbContext Db
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Now Calling - SagraFacile</PageTitle>

<div class="now-calling-fullscreen">
    @if (recentCalls != null && recentCalls.Any())
    {
        <div class="now-calling-header">
            <h1>Now Calling</h1>
        </div>
        
        <div class="calls-grid">
            <!-- Left sidebar with 2 recent calls -->
            <div class="sidebar-calls left-sidebar">
                @for (int i = 1; i < Math.Min(3, recentCalls.Count); i++)
                {
                    var call = recentCalls[i];
                    <div class="sidebar-card">
                        <div class="sidebar-queue">@call.QueueNumber</div>
                        <div class="sidebar-name">@call.CustomerName</div>
                        <div class="sidebar-party">Party of @call.PartySize</div>
                        <div class="sidebar-time">@call.LastCalledAt.ToString("HH:mm")</div>
                    </div>
                }
            </div>
            
            <!-- Center - Most recent call (largest) -->
            <div class="center-call">
                <div class="center-card">
                    <div class="center-queue">@recentCalls[0].QueueNumber</div>
                    <div class="center-name">@recentCalls[0].CustomerName</div>
                    <div class="center-party">Party of @recentCalls[0].PartySize</div>
                    <div class="center-time">Called at @recentCalls[0].LastCalledAt.ToString("HH:mm:ss")</div>
                </div>
            </div>
            
            <!-- Right sidebar with next 2 calls -->
            <div class="sidebar-calls right-sidebar">
                @for (int i = 3; i < Math.Min(5, recentCalls.Count); i++)
                {
                    var call = recentCalls[i];
                    <div class="sidebar-card">
                        <div class="sidebar-queue">@call.QueueNumber</div>
                        <div class="sidebar-name">@call.CustomerName</div>
                        <div class="sidebar-party">Party of @call.PartySize</div>
                        <div class="sidebar-time">@call.LastCalledAt.ToString("HH:mm")</div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="no-calls-container">
            <div class="now-calling-header">
                <h1>Now Calling</h1>
            </div>
            <div class="no-calls">
                <p>No reservations have been called yet</p>
            </div>
        </div>
    }
</div>

<style>
    body, html {
        margin: 0;
        padding: 0;
        overflow: hidden;
    }

    .now-calling-fullscreen {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .now-calling-header {
        text-align: center;
        padding: 40px 20px 20px;
    }

    .now-calling-header h1 {
        font-size: 4rem;
        color: white;
        margin: 0;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 4px;
        text-shadow: 3px 3px 6px rgba(0, 0, 0, 0.3);
    }

    .calls-grid {
        display: grid;
        grid-template-columns: 1fr 2fr 1fr;
        gap: 30px;
        padding: 20px 40px;
        flex: 1;
        align-items: center;
        max-height: calc(100vh - 150px);
    }

    /* Sidebar styles */
    .sidebar-calls {
        display: flex;
        flex-direction: column;
        gap: 20px;
        height: 100%;
        justify-content: center;
    }

    .sidebar-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        text-align: center;
        animation: slideIn 0.5s ease-out;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(-30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .sidebar-queue {
        font-size: 1.8rem;
        font-weight: 700;
        color: #764ba2;
        margin-bottom: 10px;
    }

    .sidebar-name {
        font-size: 1.5rem;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
    }

    .sidebar-party {
        font-size: 1.1rem;
        color: #718096;
        margin-bottom: 8px;
    }

    .sidebar-time {
        font-size: 0.9rem;
        color: #a0aec0;
        font-style: italic;
    }

    /* Center card styles */
    .center-call {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
    }

    .center-card {
        background: white;
        border-radius: 30px;
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4);
        padding: 80px 60px;
        text-align: center;
        width: 100%;
        max-width: 700px;
        animation: zoomIn 0.6s ease-out;
        border: 5px solid #f7fafc;
    }

    @@keyframes zoomIn {
        from {
            opacity: 0;
            transform: scale(0.8);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .center-queue {
        font-size: 5.5rem;
        font-weight: 900;
        color: #667eea;
        margin-bottom: 30px;
        letter-spacing: 4px;
        text-shadow: 3px 3px 6px rgba(0, 0, 0, 0.1);
    }

    .center-name {
        font-size: 4.5rem;
        font-weight: 800;
        color: #2d3748;
        margin-bottom: 25px;
        line-height: 1.2;
    }

    .center-party {
        font-size: 2.5rem;
        color: #718096;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .center-time {
        font-size: 1.8rem;
        color: #a0aec0;
        font-style: italic;
    }

    /* No calls state */
    .no-calls-container {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        height: 100%;
    }

    .no-calls {
        text-align: center;
        padding: 60px;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }

    .no-calls p {
        font-size: 3rem;
        color: #718096;
        margin: 0;
    }

    /* Responsive adjustments */
    @@media (max-width: 1400px) {
        .calls-grid {
            grid-template-columns: 1fr 2.5fr 1fr;
            gap: 20px;
            padding: 20px;
        }

        .center-queue {
            font-size: 4.5rem;
        }

        .center-name {
            font-size: 3.5rem;
        }

        .center-party {
            font-size: 2rem;
        }
    }

    @@media (max-width: 1024px) {
        .now-calling-header h1 {
            font-size: 3rem;
        }

        .calls-grid {
            grid-template-columns: 1fr;
            grid-template-rows: auto 1fr auto;
            gap: 15px;
        }

        .sidebar-calls {
            flex-direction: row;
            height: auto;
        }

        .left-sidebar {
            order: 1;
        }

        .center-call {
            order: 2;
        }

        .right-sidebar {
            order: 3;
        }

        .center-queue {
            font-size: 3.5rem;
        }

        .center-name {
            font-size: 2.8rem;
        }

        .center-party {
            font-size: 1.6rem;
        }
    }
</style>

@code {
    private List<LastCalledReservationDto> recentCalls = new();
    private HubConnection? hubConnection;
    private System.Threading.Timer? refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecentCalls();

        // Request fullscreen on page load
        await RequestFullscreen();

        // Set up SignalR connection
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/reservations"))
            .Build();

        hubConnection.On("ReservationCalled", async () =>
        {
            await LoadRecentCalls();
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();

        // Auto-refresh every 5 seconds as a backup
        refreshTimer = new System.Threading.Timer(async _ =>
        {
            await LoadRecentCalls();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task LoadRecentCalls()
    {
        recentCalls = await GetLastCalledReservationHandler.HandleMultiple(
            new GetLastCalledReservation(),
            Db,
            5
        );
    }

    private async Task RequestFullscreen()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", @"
                document.documentElement.requestFullscreen?.() || 
                document.documentElement.webkitRequestFullscreen?.() || 
                document.documentElement.msRequestFullscreen?.();
            ");
        }
        catch
        {
            // Fullscreen may fail due to browser policies, ignore errors
        }
    }

    public async ValueTask DisposeAsync()
    {
        refreshTimer?.Dispose();
        
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}

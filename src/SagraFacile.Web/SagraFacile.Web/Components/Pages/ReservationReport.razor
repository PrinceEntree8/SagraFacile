@page "/reservation-report"
@rendermode InteractiveServer
@using SagraFacile.Web.Features.Reservations
@using SagraFacile.Web.Data
@inject ApplicationDbContext DbContext

<PageTitle>Reservation Report</PageTitle>

<h1>Reservation Report</h1>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h3>Filter Options</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <label class="form-label">Start Date</label>
                        <InputDate @bind-Value="startDate" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">End Date</label>
                        <InputDate @bind-Value="endDate" class="form-control" />
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button class="btn btn-primary" @onclick="@LoadReport" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Generate Report
                        </button>
                        <button class="btn btn-outline-secondary ms-2" @onclick="@ClearFilters">
                            Clear
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (statistics != null)
{
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Total Reservations</h5>
                    <h2 class="display-4">@statistics.TotalReservations</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Seated</h5>
                    <h2 class="display-4">@statistics.SeatedCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Waiting</h5>
                    <h2 class="display-4">@statistics.WaitingCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center bg-secondary text-white">
                <div class="card-body">
                    <h5 class="card-title">Voided</h5>
                    <h2 class="display-4">@statistics.VoidedCount</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h3>Wait Time Statistics</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="text-center">
                                <h5>Average Wait</h5>
                                <p class="h4">@FormatTimeSpan(statistics.AverageWaitTime)</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h5>Median Wait</h5>
                                <p class="h4">@FormatTimeSpan(statistics.MedianWaitTime)</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h5>Min Wait</h5>
                                <p class="h4">@(statistics.MinWaitTime.HasValue ? FormatTimeSpan(statistics.MinWaitTime.Value) : "N/A")</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h5>Max Wait</h5>
                                <p class="h4">@(statistics.MaxWaitTime.HasValue ? FormatTimeSpan(statistics.MaxWaitTime.Value) : "N/A")</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <p><em>Loading report...</em></p>
}
else if (reports != null && reports.Any())
{
    <div class="card">
        <div class="card-header">
            <h3>Detailed Report</h3>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Queue #</th>
                            <th>Customer</th>
                            <th>Party Size</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>First Called</th>
                            <th>Calls</th>
                            <th>Wait Until First Call</th>
                            <th>Total Wait Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var report in reports)
                        {
                            <tr>
                                <td><strong>@report.QueueNumber</strong></td>
                                <td>@report.CustomerName</td>
                                <td><span class="badge bg-info">@report.PartySize</span></td>
                                <td><span class="badge @GetStatusBadge(report.Status)">@report.Status</span></td>
                                <td>@report.CreatedAt.ToString("g")</td>
                                <td>
                                    @if (report.FirstCalledAt.HasValue)
                                    {
                                        @report.FirstCalledAt.Value.ToString("g")
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not called</span>
                                    }
                                </td>
                                <td>@report.CallCount</td>
                                <td>
                                    @if (report.WaitTimeUntilFirstCall.HasValue)
                                    {
                                        @FormatTimeSpan(report.WaitTimeUntilFirstCall.Value)
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (report.TotalWaitTime.HasValue)
                                    {
                                        @FormatTimeSpan(report.TotalWaitTime.Value)
                                    }
                                    else
                                    {
                                        <span class="text-muted">In progress</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else if (statistics == null)
{
    <div class="alert alert-info">
        <p>Select date range and click "Generate Report" to view statistics.</p>
    </div>
}
else
{
    <div class="alert alert-warning">
        <p>No reservations found for the selected date range.</p>
    </div>
}

@code {
    private DateTime? startDate = null;
    private DateTime? endDate = null;
    private List<GetReservationReport.ReportDto> reports = new();
    private GetReservationReport.StatisticsDto? statistics = null;
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        // Don't load report automatically
    }

    private async Task LoadReport()
    {
        isLoading = true;
        try
        {
            var query = new GetReservationReport.Query(startDate, endDate);
            var handler = new GetReservationReport.Handler(DbContext);
            var result = await handler.Handle(query, CancellationToken.None);
            reports = result.Reports;
            statistics = result.Statistics;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ClearFilters()
    {
        startDate = null;
        endDate = null;
        await LoadReport();
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Waiting" => "bg-warning",
        "Called" => "bg-info",
        "Seated" => "bg-success",
        "Voided" => "bg-secondary",
        _ => "bg-secondary"
    };

    private string FormatTimeSpan(TimeSpan timeSpan)
    {
        if (timeSpan.TotalHours >= 1)
            return $"{(int)timeSpan.TotalHours}h {timeSpan.Minutes}m";
        return $"{(int)timeSpan.TotalMinutes}m";
    }
}

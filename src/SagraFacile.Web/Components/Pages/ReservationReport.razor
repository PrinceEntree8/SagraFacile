@page "/reservation-report"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@implements IAsyncDisposable

<PageTitle>@L["Report_PageTitle"]</PageTitle>

<h1>@L["Report_Heading"]</h1>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h3>@L["Report_FilterOptions"]</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <label class="form-label">@L["Report_Event"]</label>
                        <InputSelect @bind-Value="selectedEventId" class="form-select" disabled="@(!events.Any())">
                            @if (!events.Any())
                            {
                                <option value="">@L["Report_NoEventsAvailable"]</option>
                            }
                            else
                            {
                                @foreach (var ev in events)
                                {
                                    <option value="@ev.Id">@ev.Date.ToString("d") - @ev.Name</option>
                                }
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button class="btn btn-primary" @onclick="@LoadReport">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            @L["Report_Generate"]
                        </button>
                        <button class="btn btn-outline-secondary ms-2" @onclick="@ClearFilters">
                            @L["Report_Clear"]
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (statistics != null)
{
    <div class="row mb-4">
        <div class="col-md">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">@L["Report_TotalReservations"]</h5>
                    <h2 class="display-4">@statistics.TotalReservations</h2>
                </div>
            </div>
        </div>
        <div class="col-md">
            <div class="card text-center bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">@L["Report_TotalPeople"]</h5>
                    <h2 class="display-4">@statistics.TotalPeople</h2>
                </div>
            </div>
        </div>
        <div class="col-md">
            <div class="card text-center bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">@L["Report_Seated"]</h5>
                    <h2 class="display-4">@statistics.SeatedCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md">
            <div class="card text-center bg-warning">
                <div class="card-body">
                    <h5 class="card-title">@L["Report_Waiting"]</h5>
                    <h2 class="display-4">@statistics.WaitingCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md">
            <div class="card text-center bg-secondary text-white">
                <div class="card-body">
                    <h5 class="card-title">@L["Report_Voided"]</h5>
                    <h2 class="display-4">@statistics.VoidedCount</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h3>@L["Report_WaitTimeStats"]</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="text-center">
                                <h5>@L["Report_AverageWait"]</h5>
                                <p class="h4">@FormatTimeSpan(statistics.AverageWaitTime)</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h5>@L["Report_MedianWait"]</h5>
                                <p class="h4">@FormatTimeSpan(statistics.MedianWaitTime)</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h5>@L["Report_MinWait"]</h5>
                                <p class="h4">@(statistics.MinWaitTime.HasValue ? FormatTimeSpan(statistics.MinWaitTime.Value) : "N/A")</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h5>@L["Report_MaxWait"]</h5>
                                <p class="h4">@(statistics.MaxWaitTime.HasValue ? FormatTimeSpan(statistics.MaxWaitTime.Value) : "N/A")</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (isLoading)
{
    <p><em>@L["Report_Loading"]</em></p>
}
else if (reports != null && reports.Any())
{
    <div class="card">
        <div class="card-header">
            <h3>@L["Report_DetailedReport"]</h3>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>@L["Report_ColQueue"]</th>
                            <th>@L["Report_ColCustomer"]</th>
                            <th>@L["Report_ColPartySize"]</th>
                            <th>@L["Report_ColStatus"]</th>
                            <th>@L["Report_ColCreated"]</th>
                            <th>@L["Report_ColFirstCalled"]</th>
                            <th>@L["Report_ColCalls"]</th>
                            <th>@L["Report_ColWaitUntilFirst"]</th>
                            <th>@L["Report_ColTotalWait"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var report in reports)
                        {
                            <tr>
                                <td><strong>@report.SequenceNumber</strong></td>
                                <td>@report.CustomerName</td>
                                <td><span class="badge bg-info">@report.PartySize</span></td>
                                <td><span class="badge @GetStatusBadge(report.Status)">@report.Status</span></td>
                                <td>@report.CreatedAt.ToString("g")</td>
                                <td>
                                    @if (report.FirstCalledAt.HasValue)
                                    {
                                        @report.FirstCalledAt.Value.ToString("g")
                                    }
                                    else
                                    {
                                        <span class="text-muted">@L["Report_NotCalled"]</span>
                                    }
                                </td>
                                <td>@report.CallCount</td>
                                <td>
                                    @if (report.WaitTimeUntilFirstCall.HasValue)
                                    {
                                        @FormatTimeSpan(report.WaitTimeUntilFirstCall.Value)
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (report.TotalWaitTime.HasValue)
                                    {
                                        @FormatTimeSpan(report.TotalWaitTime.Value)
                                    }
                                    else
                                    {
                                        <span class="text-muted">@L["Report_InProgress"]</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else if (statistics == null)
{
    <div class="alert alert-info">
        <p>@L["Report_SelectEvent"]</p>
    </div>
}
else
{
    <div class="alert alert-warning">
        <p>@L["Report_NoReservations"]</p>
    </div>
}

@code {
    private List<GetEvents.EventDto> events = new();
    private int? selectedEventId;
    private int? defaultEventId;
    private List<GetReservationReport.ReportDto> reports = new();
    private GetReservationReport.StatisticsDto? statistics = null;
    private bool isLoading = false;
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        var activeEventTask = Mediator.QueryAsync(new GetActiveEvent.Query());
        var eventsTask = Mediator.QueryAsync(new GetEvents.Query());
        await Task.WhenAll(activeEventTask, eventsTask);

        var activeEvent = (await activeEventTask).ActiveEvent;
        events = (await eventsTask).Events;
        defaultEventId = activeEvent?.Id ?? events.FirstOrDefault()?.Id;
        selectedEventId = defaultEventId;

        if (selectedEventId.HasValue)
        {
            await LoadReport();
        }

        await InitializeSignalR();
    }

    private async Task LoadReport()
    {
        if (!selectedEventId.HasValue)
        {
            reports = new();
            statistics = null;
            return;
        }

        isLoading = true;
        try
        {
            var query = new GetReservationReport.Query(selectedEventId);
            var result = await Mediator.Send(query, CancellationToken.None);
            reports = result.Reports;
            statistics = result.Statistics;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ClearFilters()
    {
        selectedEventId = defaultEventId;
        await LoadReport();
    }

    private async Task InitializeSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/reservations"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<int, string, string, int>("ReservationCreated", async (_, _, _, _) =>
        {
            await LoadReport();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string, string, int, int>("ReservationCalled", async (_, _, _, _, _) =>
        {
            await LoadReport();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string>("ReservationVoided", async (_, _) =>
        {
            await LoadReport();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string>("ReservationSeated", async (_, _) =>
        {
            await LoadReport();
            await InvokeAsync(StateHasChanged);
        });

        try
        {
            await hubConnection.StartAsync();
        }
        catch
        {
            // Keep report page functional even if realtime connection is unavailable.
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Waiting" => "bg-warning",
        "Called" => "bg-info",
        "Seated" => "bg-success",
        "Voided" => "bg-secondary",
        _ => "bg-secondary"
    };

    private string FormatTimeSpan(TimeSpan timeSpan)
    {
        if (timeSpan.TotalHours >= 1)
            return $"{(int)timeSpan.TotalHours}h {timeSpan.Minutes}m";
        return $"{(int)timeSpan.TotalMinutes}m";
    }
}

@page "/headwaiter"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@implements IAsyncDisposable

<PageTitle>@L["HeadWaiter_PageTitle"]</PageTitle>

<h1>@L["HeadWaiter_Heading"]</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header">
                <h3>@L["HeadWaiter_AnnounceSeats"]</h3>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">@L["HeadWaiter_NumberOfSeats"]</label>
                    <div class="input-group">
                        <InputNumber @bind-Value="availableSeatsToAnnounce" class="form-control" min="0" />
                        <button class="btn btn-primary" @onclick="@AnnounceAvailableSeats" disabled="@(isAnnouncing || actionInProgress != null)">
                            @if (isAnnouncing)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            @L["HeadWaiter_Announce"]
                        </button>
                    </div>
                    <small class="text-muted">@L["HeadWaiter_ShownAtReception"]</small>
                </div>

                @if (!string.IsNullOrEmpty(announcementMessage))
                {
                    <div class="alert alert-success mt-3">@announcementMessage</div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h3>@L["HeadWaiter_BestFit"]</h3>
                @if (coverCountForSearch > 0)
                {
                    <p class="mb-0">@string.Format(L["HeadWaiter_ForSeats"], coverCountForSearch)</p>
                }
                else
                {
                    <p class="mb-0">@L["HeadWaiter_AllCalled"]</p>
                }
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">@L["HeadWaiter_CoverFilter"]</label>
                    <div class="input-group">
                        <InputNumber @bind-Value="coverCountForSearch" class="form-control" placeholder="All" />
                        <button class="btn btn-outline-primary" @onclick="@SearchBestFit">@L["HeadWaiter_Filter"]</button>
                        <button class="btn btn-outline-secondary" @onclick="@ClearFilter">@L["HeadWaiter_Clear"]</button>
                    </div>
                    <small class="text-muted">@L["HeadWaiter_FilterHint"]</small>
                </div>

                @if (isSearching)
                {
                    <p><em>@L["HeadWaiter_Searching"]</em></p>
                }
                else if (bestFitResults != null)
                {
                    @if (bestFitResults.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>@L["HeadWaiter_ColMatch"]</th>
                                        <th>@L["HeadWaiter_ColQueue"]</th>
                                        <th>@L["HeadWaiter_ColName"]</th>
                                        <th>@L["HeadWaiter_ColPartySize"]</th>
                                        <th>@L["HeadWaiter_ColNotes"]</th>
                                        <th>@L["HeadWaiter_ColWaiting"]</th>
                                        <th>@L["HeadWaiter_ColCalls"]</th>
                                        <th>@L["HeadWaiter_ColLastCall"]</th>
                                        <th>@L["HeadWaiter_ColActions"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var match in bestFitResults)
                                    {
                                        <tr class="@GetMatchRowClass(match)">
                                            <td>
                                                <span class="badge @GetMatchBadge(match.MatchQuality)">
                                                    @match.MatchQuality
                                                </span>
                                            </td>
                                            <td><strong>@match.QueueNumber</strong></td>
                                            <td>@match.CustomerName</td>
                                            <td>
                                                <span class="badge bg-info">@match.PartySize</span>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(match.Notes))
                                                {
                                                    <span class="text-muted">@match.Notes</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>@FormatTimeSpan(match.WaitingTime)</td>
                                            <td>@match.CallCount</td>
                                            <td>
                                                @if (match.LastCalledAt.HasValue)
                                                {
                                                    @FormatTimeSpan(DateTime.UtcNow - match.LastCalledAt.Value)
                                                }
                                                else
                                                {
                                                    <span class="text-muted">@L["HeadWaiter_Never"]</span>
                                                }
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-primary" @onclick="@(() => SeatReservationAsync(match.Id))" disabled="@(actionInProgress == match.Id)">
                                                    @L["HeadWaiter_Seat"]
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="alert alert-info mt-3">
                            <strong>@string.Format(L["HeadWaiter_BestRecommendation"], bestFitResults.First().QueueNumber, bestFitResults.First().CustomerName, bestFitResults.First().PartySize)</strong>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            @L["HeadWaiter_NoMatch"]
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    private HubConnection? hubConnection;
    private List<GetBestFitReservation.ReservationMatchDto> bestFitResults = new();
    private int coverCountForSearch = 0;
    private int availableSeatsToAnnounce = 0;
    private bool isAnnouncing = false;
    private string announcementMessage = string.Empty;
    private int? actionInProgress = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadAllCalledReservations(); // Load all Called reservations by default
        await InitializeSignalR();
    }

    private async Task InitializeSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/reservations"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<int, string, string, int>("ReservationCreated", async (id, queueNumber, name, size) =>
        {
            if (coverCountForSearch > 0)
            {
                await SearchBestFit();
            }
            else
            {
                await LoadAllCalledReservations(); // Refresh the default view
            }
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string, string, int, int>("ReservationCalled", async (id, queueNumber, customerName, partySize, callCount) =>
        {
            if (coverCountForSearch > 0)
            {
                await SearchBestFit();
            }
            else
            {
                await LoadAllCalledReservations(); // Refresh the default view
            }
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string>("ReservationVoided", async (id, queueNumber) =>
        {
            if (coverCountForSearch > 0)
            {
                await SearchBestFit();
            }
            else
            {
                await LoadAllCalledReservations(); // Refresh the default view
            }
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string>("ReservationSeated", async (id, queueNumber) =>
        {
            if (coverCountForSearch > 0)
            {
                await SearchBestFit();
            }
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
    }

    private async Task LoadAllCalledReservations()
    {
        isSearching = true;
        try
        {
            // Load all Called reservations without a specific cover count filter
            var query = new GetBestFitReservation.Query(0); // Use 0 to indicate "all"
            var result = await Mediator.Send(query, CancellationToken.None);
            bestFitResults = result.Matches.ToList();
        }
        finally
        {
            isSearching = false;
        }
    }

    private async Task AnnounceAvailableSeats()
    {
        isAnnouncing = true;
        announcementMessage = string.Empty;
        try
        {
            if (hubConnection?.State == HubConnectionState.Connected)
            {
                await hubConnection.SendAsync("NotifyAvailableSeatsUpdated", availableSeatsToAnnounce);
            announcementMessage = string.Format(L["HeadWaiter_Announced"], availableSeatsToAnnounce);
                
                // Also update the filter to show who fits
                coverCountForSearch = availableSeatsToAnnounce;
                await SearchBestFit();
            }
        }
        catch (Exception ex)
        {
            announcementMessage = string.Format(L["HeadWaiter_Error"], ex.Message);
        }
        finally
        {
            isAnnouncing = false;
        }
    }

    private async Task ClearFilter()
    {
        coverCountForSearch = 0;
        await LoadAllCalledReservations();
    }

    private async Task SearchBestFit()
    {
        if (coverCountForSearch <= 0)
        {
            await LoadAllCalledReservations();
            return;
        }

        isSearching = true;
        try
        {
            var query = new GetBestFitReservation.Query(coverCountForSearch);
            var result = await Mediator.Send(query, CancellationToken.None);
            bestFitResults = result.Matches;
        }
        finally
        {
            isSearching = false;
        }
    }

    private bool isSearching = false;

    private string GetMatchBadge(string matchQuality) => matchQuality switch
    {
        "Perfect" => "bg-success",
        "Good" => "bg-primary",
        "Acceptable" => "bg-info",
        "Fits" => "bg-secondary",
        _ => "bg-secondary"
    };

    private string GetMatchRowClass(GetBestFitReservation.ReservationMatchDto match)
    {
        if (match.MatchQuality == "Perfect")
            return "table-success";
        return "";
    }

    private string FormatTimeSpan(TimeSpan timeSpan)
    {
        if (timeSpan.TotalHours >= 1)
            return $"{(int)timeSpan.TotalHours}h {timeSpan.Minutes}m";
        return $"{(int)timeSpan.TotalMinutes}m";
    }

    private async Task SeatReservationAsync(int reservationId)
    {
        actionInProgress = reservationId;
        try
        {
            var command = new SeatReservation.Command(reservationId);
            await Mediator.Send(command, CancellationToken.None);
            
            // Notify via SignalR
            if (hubConnection?.State == HubConnectionState.Connected)
            {
                var match = bestFitResults.FirstOrDefault(r => r.Id == reservationId);
                if (match != null)
                {
                    await hubConnection.SendAsync("NotifyReservationSeated", reservationId, match.QueueNumber);
                }
            }
            
            // Refresh the best fit results
            if (coverCountForSearch > 0)
            {
                await SearchBestFit();
            }
            else
            {
                await LoadAllCalledReservations();
            }
        }
        catch (Exception ex)
        {
            announcementMessage = string.Format(L["HeadWaiter_ErrorSeating"], ex.Message);
        }
        finally
        {
            actionInProgress = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}

@page "/headwaiter"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using SagraFacile.Web.Hubs
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@inject ILogger<HeadWaiter> Logger
@implements IAsyncDisposable

<PageTitle>@L["HeadWaiter_PageTitle"]</PageTitle>

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <h1 class="mb-0">@L["HeadWaiter_Heading"]</h1>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#announceModal">
            <i class="bi bi-megaphone-fill"></i>
            <span class="d-none d-md-inline">@L["HeadWaiter_AnnounceSeats"]</span>
        </button>
        <button class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#manualSeatModal">
            <i class="bi bi-person-plus-fill"></i>
            <span class="d-none d-md-inline">@L["HeadWaiter_ManualSeat"]</span>
        </button>
    </div>
</div>

<div class="col-12">
    <div class="card">
        <div class="card-header">
            <h3>@L["HeadWaiter_BestFit"]</h3>
            @if (coverCountForSearch > 0)
            {
                <p class="mb-0">@string.Format(L["HeadWaiter_ForSeats"], coverCountForSearch)</p>
            }
            else
            {
                <p class="mb-0">@L["HeadWaiter_AllCalled"]</p>
            }
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">@L["HeadWaiter_CoverFilter"]</label>
                <div class="input-group headwaiter-filter-actions">
                    <InputNumber @bind-Value="coverCountForSearch" class="form-control" placeholder="@L["HeadWaiter_CoverFilterPlaceholder"]" />
                    <button class="btn btn-outline-primary" @onclick="@SearchBestFit">@L["HeadWaiter_Filter"]</button>
                    <button class="btn btn-outline-secondary" @onclick="@ClearFilter">@L["HeadWaiter_Clear"]</button>
                </div>
                <small class="text-muted">@L["HeadWaiter_FilterHint"]</small>
            </div>

            @if (!string.IsNullOrEmpty(signalRError))
            {
                <div class="alert alert-warning">@signalRError</div>
            }
            @if (!string.IsNullOrEmpty(seatError))
            {
                <div class="alert alert-danger">@seatError</div>
            }
            @if (isSearching)
            {
                <p><em>@L["HeadWaiter_Searching"]</em></p>
            }
            else if (bestFitResults != null)
            {
                @if (bestFitResults.Any())
                {
                    <div class="match-list" id="headwaiter-mobile-accordion">
                        @* Desktop header *@
                        <div class="row fw-semibold d-none d-md-flex border-bottom pb-2 mb-1 px-2 text-muted small text-uppercase">
                            <div class="col-md-2"><i class="bi bi-list-ul"></i></div>
                            <div class="col-md-2"><i class="bi bi-people"></i></div>
                            <div class="col-md-4">@L["HeadWaiter_ColName"]</div>
                            <div class="col-md-2">@L["HeadWaiter_ColWaitTime"]</div>
                            <div class="col-md-2">@L["HeadWaiter_Actions"]</div>
                        </div>

                        @foreach (var match in bestFitResults)
                        {
                            var collapseId = $"accordion-{match.Id}";
                            <div class="border-bottom @GetMatchRowClass(match)">
                                @* Desktop row *@
                                <div class="row align-items-center py-2 px-2 d-none d-md-flex">
                                    <div class="col-md-2">
                                        <strong>@match.SequenceNumber</strong>
                                    </div>
                                    <div class="col-md-2">
                                        <span class="badge bg-info">@match.PartySize</span>
                                    </div>
                                    <div class="col-md-4">
                                        @match.CustomerName
                                    </div>
                                    <div class="col-md-2">
                                        @if (match.LastCalledAt.HasValue)
                                        {
                                            @FormatTimeSpan(DateTime.UtcNow - match.LastCalledAt.Value)
                                        }
                                        else
                                        {
                                            <span class="text-muted">@L["HeadWaiter_Never"]</span>
                                        }
                                    </div>
                                    <div class="col-md-2">
                                        <button class="btn btn-sm btn-primary" @onclick="@(() => SeatReservationAsync(match.Id))" disabled="@(actionInProgress == match.Id)">
                                            @if (actionInProgress == match.Id)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1"></span>
                                            }
                                            @L["HeadWaiter_Seat"]
                                        </button>
                                    </div>
                                </div>

                                @* Mobile summary row (accordion trigger) *@
                                <div class="d-flex d-md-none align-items-center justify-content-between px-2 py-2" style="cursor:pointer" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false">
                                    <div class="d-flex align-items-center gap-2">
                                        <strong>@match.SequenceNumber</strong> - @match.CustomerName
                                    </div>
                                    <span class="badge bg-info float-end">@match.PartySize <i class="bi bi-people"></i></span>
                                </div>

                                @* Mobile accordion detail *@
                                <div class="collapse d-md-none px-2 pb-2" id="@collapseId" data-bs-parent="#headwaiter-mobile-accordion">
                                    <div class="mb-1"><span class="text-muted small">@L["HeadWaiter_ColName"]: </span>@match.CustomerName</div>
                                    <div class="mb-2">
                                        <span class="text-muted small">@L["HeadWaiter_ColWaitTime"]: </span>
                                        @if (match.LastCalledAt.HasValue)
                                        {
                                            @FormatTimeSpan(DateTime.UtcNow - match.LastCalledAt.Value)
                                        }
                                        else
                                        {
                                            <span class="text-muted">@L["HeadWaiter_Never"]</span>
                                        }
                                    </div>
                                    <button class="btn btn-sm btn-primary w-100" @onclick="@(() => SeatReservationAsync(match.Id))" disabled="@(actionInProgress == match.Id)">
                                        @if (actionInProgress == match.Id)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        @L["HeadWaiter_Seat"]
                                    </button>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="alert alert-info mt-3">
                        <strong>@string.Format(L["HeadWaiter_BestRecommendation"], bestFitResults.First().SequenceNumber, bestFitResults.First().CustomerName, bestFitResults.First().PartySize)</strong>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning">
                        @L["HeadWaiter_NoMatch"]
                    </div>
                }
            }
        </div>
    </div>
</div>

@* Announce Modal *@
<div class="modal fade" id="announceModal" tabindex="-1" aria-labelledby="announceModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="announceModalLabel">@L["HeadWaiter_AnnounceSeatsTitle"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">@L["HeadWaiter_NumberOfSeats"]</label>
                    <InputNumber @bind-Value="availableSeatsToAnnounce" class="form-control" min="0" />
                    <small class="text-muted">@L["HeadWaiter_ShownAtReception"]</small>
                </div>
                @if (!string.IsNullOrEmpty(announcementMessage))
                {
                    <div class="alert alert-success">@announcementMessage</div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@L["Common_Close"]</button>
                <button class="btn btn-primary" @onclick="@AnnounceAvailableSeats" disabled="@isAnnouncing">
                    @if (isAnnouncing)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    @L["HeadWaiter_Announce"]
                </button>
            </div>
        </div>
    </div>
</div>

@* Manual Seat Modal *@
<div class="modal fade" id="manualSeatModal" tabindex="-1" aria-labelledby="manualSeatModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="manualSeatModalLabel">@L["HeadWaiter_ManualSeatTitle"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small">@L["HeadWaiter_ManualSeatHint"]</p>
                <div class="mb-3">
                    <label class="form-label">@L["HeadWaiter_QueueNumber"]</label>
                    <input type="text" class="form-control" @bind="manualSeatQueueNumber" placeholder="@L["HeadWaiter_QueueNumberPlaceholder"]" />
                </div>
                @if (!string.IsNullOrEmpty(manualSeatError))
                {
                    <div class="alert alert-danger">@manualSeatError</div>
                }
                @if (!string.IsNullOrEmpty(manualSeatSuccess))
                {
                    <div class="alert alert-success">@manualSeatSuccess</div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@L["Common_Close"]</button>
                <button class="btn btn-warning" @onclick="@CallAndSeatAsync" data-bs-dismiss="modal" disabled="@isManualSeating">
                    @if (isManualSeating)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    @L["HeadWaiter_CallAndSeat"]
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private HubConnection? hubConnection;
    private List<GetBestFitReservation.ReservationMatchDto> bestFitResults = new();
    private int coverCountForSearch = 0;
    private int availableSeatsToAnnounce = 0;
    private bool isAnnouncing = false;
    private string announcementMessage = string.Empty;
    private int? actionInProgress = null;
    private bool isSearching = false;

    // Manual Seat modal state
    private int activeEventId = 1; // TODO: replace with session-backed active event store
    private string manualSeatQueueNumber = string.Empty;
    private string manualSeatError = string.Empty;
    private string manualSeatSuccess = string.Empty;
    private bool isManualSeating = false;
    private string seatError = string.Empty;
    private string signalRError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAllCalledReservations();
        await InitializeSignalR();
    }

    private async Task InitializeSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/reservations"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<int, int, string, int>(nameof(IReservationHubClient.ReservationCreated), async (id, sequenceNumber, name, size) =>
        {
            if (coverCountForSearch > 0)
                await SearchBestFit();
            else
                await LoadAllCalledReservations();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, int, string, int, int>(nameof(IReservationHubClient.ReservationCalled), async (id, sequenceNumber, customerName, partySize, callCount) =>
        {
            if (coverCountForSearch > 0)
                await SearchBestFit();
            else
                await LoadAllCalledReservations();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, int>("ReservationVoided", async (id, sequenceNumber) =>
        {
            if (coverCountForSearch > 0)
                await SearchBestFit();
            else
                await LoadAllCalledReservations();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, int>("ReservationSeated", async (id, sequenceNumber) =>
        {
            if (coverCountForSearch > 0)
                await SearchBestFit();
            else
                await LoadAllCalledReservations();
            await InvokeAsync(StateHasChanged);
        });

        try
        {
            await hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "SignalR initialization failed");
            signalRError = L["HeadWaiter_SignalRError"];
        }
    }

    private async Task LoadAllCalledReservations()
    {
        isSearching = true;
        try
        {
            var query = new GetBestFitReservation.Query(activeEventId, 0);
            var result = await Mediator.Send(query, CancellationToken.None);
            bestFitResults = result.Matches.ToList();
        }
        finally
        {
            isSearching = false;
        }
    }

    private async Task AnnounceAvailableSeats()
    {
        isAnnouncing = true;
        announcementMessage = string.Empty;
        try
        {
            if (hubConnection?.State == HubConnectionState.Connected)
            {
                await hubConnection.SendAsync("NotifyAvailableSeatsUpdated", availableSeatsToAnnounce);
                announcementMessage = string.Format(L["HeadWaiter_Announced"], availableSeatsToAnnounce);

                coverCountForSearch = availableSeatsToAnnounce;
                await SearchBestFit();
            }
        }
        catch (Exception ex)
        {
            announcementMessage = string.Format(L["HeadWaiter_Error"], ex.Message);
        }
        finally
        {
            isAnnouncing = false;
        }
    }

    private async Task ClearFilter()
    {
        coverCountForSearch = 0;
        await LoadAllCalledReservations();
    }

    private async Task SearchBestFit()
    {
        if (coverCountForSearch <= 0)
        {
            await LoadAllCalledReservations();
            return;
        }

        isSearching = true;
        try
        {
            var query = new GetBestFitReservation.Query(activeEventId, coverCountForSearch);
            var result = await Mediator.Send(query, CancellationToken.None);
            bestFitResults = result.Matches;
        }
        finally
        {
            isSearching = false;
        }
    }

    private string GetMatchRowClass(GetBestFitReservation.ReservationMatchDto match) => match.MatchQuality switch
    {
        "Perfect" => "bg-success bg-opacity-10",
        "Good" => "bg-primary bg-opacity-10",
        "Acceptable" => "bg-info bg-opacity-10",
        "Fits" => "bg-secondary bg-opacity-10",
        _ => ""
    };

    private string FormatTimeSpan(TimeSpan timeSpan)
    {
        if (timeSpan.TotalHours >= 1)
            return $"{(int)timeSpan.TotalHours}h {timeSpan.Minutes}m";
        return $"{(int)timeSpan.TotalMinutes}m";
    }

    private async Task SeatReservationAsync(int reservationId)
    {
        actionInProgress = reservationId;
        seatError = string.Empty;
        try
        {
            var command = new SeatReservation.Command(reservationId);
            await Mediator.Send(command, CancellationToken.None);

            if (coverCountForSearch > 0)
                await SearchBestFit();
            else
                await LoadAllCalledReservations();
        }
        catch (Exception ex)
        {
            seatError = string.Format(L["HeadWaiter_ErrorSeating"], ex.Message);
        }
        finally
        {
            actionInProgress = null;
        }
    }

    private async Task CallAndSeatAsync()
    {
        manualSeatError = string.Empty;
        manualSeatSuccess = string.Empty;

        if (string.IsNullOrWhiteSpace(manualSeatQueueNumber))
        {
            manualSeatError = L["HeadWaiter_ManualSeatQueueRequired"];
            return;
        }

        isManualSeating = true;
        try
        {
            if (!int.TryParse(manualSeatQueueNumber.Trim(), out var seqNum))
            {
                manualSeatError = L["HeadWaiter_ManualSeatQueueRequired"];
                return;
            }
            var command = new CallAndSeatReservation.Command(activeEventId, seqNum);
            var result = await Mediator.Send(command, CancellationToken.None);

            if (result.Success)
            {
                manualSeatSuccess = result.Message;
                manualSeatQueueNumber = string.Empty;

                if (coverCountForSearch > 0)
                    await SearchBestFit();
                else
                    await LoadAllCalledReservations();
            }
            else
            {
                manualSeatError = result.Message;
            }
        }
        catch (Exception ex)
        {
            manualSeatError = string.Format(L["HeadWaiter_Error"], ex.Message);
        }
        finally
        {
            isManualSeating = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
            await hubConnection.DisposeAsync();
    }
}

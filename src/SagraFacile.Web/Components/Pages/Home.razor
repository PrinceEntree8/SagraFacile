@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@inject IMediator Mediator
@inject IStringLocalizer<SharedResource> L
@implements IAsyncDisposable

<PageTitle>@L["Home_PageTitle"]</PageTitle>

<div class="home-container container py-4">
    @if (isLoading)
    {
        <p class="text-center"><em>@L["PublicMenu_Loading"]</em></p>
    }
    else if (activeEvent is null)
    {
        <div class="text-center text-muted mt-5">
            <h2>🍽️ @L["PublicMenu_NoActiveEvent"]</h2>
        </div>
    }
    else
    {
        <div class="text-center mb-4">
            <h1>🍽️ @activeEvent.Name</h1>
        </div>

        <div class="text-center mb-4">
            <a class="btn btn-primary btn-lg home-menu-button" href="/menu">
                @L["Home_GoToMenu"]
            </a>
        </div>

        @if (initialLoadFailed)
        {
            <div class="alert alert-warning" role="alert">
                @L["NowCalling_LoadWarning"]
            </div>
        }

        @if (calledEntries.Count == 0)
        {
            <div class="text-center text-muted mt-4" role="status" aria-live="polite">
                <p class="fs-5 mb-0">@L["NowCalling_WaitingForCall"]</p>
            </div>
        }
        else
        {
            var lastCalled = calledEntries[0];
            <section class="mb-4" aria-label="Last called reservation" aria-live="assertive">
                <h2 class="h4 mb-3">@L["Home_LastCalled"]</h2>
                <div class="card home-last-called-card">
                    <div class="card-body">
                        <div class="home-entry-queue">#@lastCalled.SequenceNumber</div>
                        <div class="home-entry-name">@lastCalled.CustomerName</div>
                        <div class="home-entry-party"><i class="bi bi-people"></i> @lastCalled.PartySize</div>
                    </div>
                </div>
            </section>

            @if (calledEntries.Count > 1)
            {
                <section aria-label="Latest called reservations">
                    <h2 class="h5 mb-3">@L["Home_LatestNineCalled"]</h2>
                    <ul class="list-group home-latest-list" role="list">
                        @foreach (var entry in calledEntries.Skip(1).Take(9))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center" role="listitem">
                                <span class="home-entry-queue">#@entry.SequenceNumber</span>
                                <span class="home-entry-name">@entry.CustomerName</span>
                                <span class="home-entry-party"><i class="bi bi-people"></i> @entry.PartySize</span>
                            </li>
                        }
                    </ul>
                </section>
            }
        }
    }
</div>

@code {
    private bool isLoading = true;
    private GetActiveEvent.EventDto? activeEvent;
    private readonly List<CalledEntry> calledEntries = [];
    private HubConnection? hubConnection;
    private const int MaxEntries = 10;
    private bool initialLoadFailed;

    protected override async Task OnInitializedAsync()
    {
        var activeResult = await Mediator.QueryAsync(new GetActiveEvent.Query());
        activeEvent = activeResult.ActiveEvent;
        if (activeEvent is not null)
        {
            await LoadInitialCalledReservationsAsync(activeEvent.Id);
            await InitializeSignalRAsync();
        }
        isLoading = false;
    }

    private async Task LoadInitialCalledReservationsAsync(int eventId)
    {
        try
        {
            var result = await Mediator.QueryAsync(new GetReservations.Query(EventId: eventId, Status: "Called", Page: 1, PageSize: MaxEntries));
            var sorted = result.Reservations
                .Where(r => r.LastCalledAt.HasValue)
                .OrderByDescending(r => r.LastCalledAt!.Value)
                .Take(MaxEntries);

            calledEntries.Clear();
            calledEntries.AddRange(sorted.Select(r => new CalledEntry(
                r.Id,
                r.SequenceNumber,
                r.CustomerName,
                r.PartySize)));
        }
        catch
        {
            initialLoadFailed = true;
        }
    }

    private async Task InitializeSignalRAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/reservations"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<int, int, string, int, int>(
            "ReservationCalled",
            async (id, sequenceNumber, customerName, partySize, _) =>
            {
                calledEntries.RemoveAll(e => e.Id == id);
                calledEntries.Insert(0, new CalledEntry(id, sequenceNumber, customerName, partySize));
                if (calledEntries.Count > MaxEntries)
                {
                    calledEntries.RemoveRange(MaxEntries, calledEntries.Count - MaxEntries);
                }

                await InvokeAsync(StateHasChanged);
            });

        hubConnection.On<int, int>("ReservationVoided", async (id, _) =>
        {
            calledEntries.RemoveAll(e => e.Id == id);
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, int>("ReservationSeated", async (id, _) =>
        {
            calledEntries.RemoveAll(e => e.Id == id);
            await InvokeAsync(StateHasChanged);
        });

        try
        {
            await hubConnection.StartAsync();
            if (hubConnection.State == HubConnectionState.Connected)
            {
                await hubConnection.SendAsync("JoinReservationGroup", "NOW_CALLING");
            }
        }
        catch
        {
            // No-op: page still works with initial snapshot if connection fails.
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private record CalledEntry(int Id, int SequenceNumber, string CustomerName, int PartySize);
}

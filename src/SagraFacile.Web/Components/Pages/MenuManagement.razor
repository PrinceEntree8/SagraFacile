@page "/events/{EventId:int}/menu"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Supervisore")]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["MenuMgmt_PageTitle"]</PageTitle>

<h1>🍽️ @L["MenuMgmt_Heading"] — @eventName</h1>
<a href="/events" class="btn btn-outline-secondary btn-sm mb-3">← @L["MenuMgmt_BackToEvents"]</a>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(messageSuccess ? "alert-success" : "alert-danger") alert-dismissible">
        @message
        <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
    </div>
}

<!-- Category management accordion -->
<div class="accordion mb-4" id="catAccordion">
    <div class="accordion-item">
        <h2 class="accordion-header">
            <button class="accordion-button collapsed" type="button"
                    data-bs-toggle="collapse" data-bs-target="#catCollapse">
                ⚙️ @L["MenuMgmt_ManageCategories"]
            </button>
        </h2>
        <div id="catCollapse" class="accordion-collapse collapse">
            <div class="accordion-body">
                <div class="row g-2 mb-3">
                    <div class="col-sm-4">
                        <input class="form-control" placeholder="@L["MenuMgmt_CatNameEn"]" @bind="catForm.Name" />
                    </div>
                    <div class="col-sm-4">
                        <input class="form-control" placeholder="@L["MenuMgmt_CatNameIt"]" @bind="catForm.NameIt" />
                    </div>
                    <div class="col-sm-2">
                        <input type="number" class="form-control" placeholder="@L["MenuMgmt_CatOrder"]" @bind="catForm.DisplayOrder" />
                    </div>
                    <div class="col-sm-2">
                        <button class="btn @(editingCatId.HasValue ? "btn-warning" : "btn-primary") w-100"
                                @onclick="SaveCategoryAsync" disabled="@isSavingCat">
                            @if (isSavingCat) { <span class="spinner-border spinner-border-sm"></span> }
                            else { @(editingCatId.HasValue ? L["MenuMgmt_SaveChanges"] : L["MenuMgmt_CatAdd"]) }
                        </button>
                    </div>
                </div>
                @if (editingCatId.HasValue)
                {
                    <button class="btn btn-outline-secondary btn-sm mb-2" @onclick="CancelCatEdit">@L["MenuMgmt_Cancel"]</button>
                }
                <table class="table table-sm">
                    <thead><tr><th>@L["MenuMgmt_CatNameEn"]</th><th>@L["MenuMgmt_CatNameIt"]</th><th>@L["MenuMgmt_CatOrder"]</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var c in categories)
                        {
                            <tr>
                                <td>@c.Name</td>
                                <td>@c.NameIt</td>
                                <td>@c.DisplayOrder</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditCategory(c)">@L["MenuMgmt_Edit"]</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCategoryAsync(c.Id)" disabled="@(deletingCatId == c.Id)">
                                        @if (deletingCatId == c.Id) { <span class="spinner-border spinner-border-sm"></span> }
                                        else { @L["MenuMgmt_Delete"] }
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Item form -->
    <div class="col-lg-5">
        <div class="card mb-4">
            <div class="card-header @(editingId.HasValue ? "bg-warning text-dark" : "bg-primary text-white")">
                <h5 class="mb-0">@(editingId.HasValue ? L["MenuMgmt_EditItem"] : L["MenuMgmt_NewItem"])</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">@L["MenuMgmt_ItemName"] *</label>
                    <input class="form-control" @bind="form.Name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">@L["MenuMgmt_ItemDescription"]</label>
                    <textarea class="form-control" rows="2" @bind="form.Description"></textarea>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">@L["MenuMgmt_ItemPrice"] * (@eventCurrencySymbol)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               value="@(form.PriceInCents / 100.0)"
                               @onchange="e => form.PriceInCents = ToCents(e.Value?.ToString())" />
                        <div class="form-text">@L["MenuMgmt_PriceHint"]</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">@L["MenuMgmt_ItemCategory"] *</label>
                        <select class="form-select" @bind="form.CategoryId">
                            <option value="0">— @L["MenuMgmt_SelectCategory"] —</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@GetCategoryName(cat)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">@L["MenuMgmt_ItemAllergens"]</label>
                    <div class="border rounded p-2" style="max-height:160px;overflow-y:auto;">
                        @foreach (var a in allergens)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="allergen_@a.Id"
                                       checked="@form.AllergenIds.Contains(a.Id)"
                                       @onchange="e => ToggleAllergen(a.Id, (bool)e.Value!)" />
                                <label class="form-check-label" for="allergen_@a.Id">
                                    @a.Icon @GetAllergenName(a)
                                </label>
                            </div>
                        }
                    </div>
                </div>
                <div class="mb-3 form-check">
                    <input class="form-check-input" type="checkbox" id="chkAvailable" @bind="form.IsAvailable" />
                    <label class="form-check-label" for="chkAvailable">@L["MenuMgmt_ItemAvailable"]</label>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn @(editingId.HasValue ? "btn-warning" : "btn-primary")"
                            @onclick="SaveItemAsync" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(editingId.HasValue ? L["MenuMgmt_SaveChanges"] : L["MenuMgmt_AddItem"])
                    </button>
                    @if (editingId.HasValue)
                    {
                        <button class="btn btn-outline-secondary" @onclick="CancelEdit">@L["MenuMgmt_Cancel"]</button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Item list -->
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">@L["MenuMgmt_AllItems"]</h5>
            </div>
            <div class="card-body">
                @if (isLoading)
                {
                    <p><em>@L["MenuMgmt_Loading"]</em></p>
                }
                else if (!items.Any())
                {
                    <p class="text-muted">@L["MenuMgmt_NoItems"]</p>
                }
                else
                {
                    @foreach (var catGroup in items.GroupBy(i => i.CategoryId)
                        .OrderBy(g => categories.FirstOrDefault(c => c.Id == g.Key)?.DisplayOrder ?? 999))
                    {
                        var cat = categories.FirstOrDefault(c => c.Id == catGroup.Key);
                        <h6 class="mt-3 text-uppercase text-muted">@(cat is null ? "?" : GetCategoryName(cat))</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead><tr>
                                    <th>@L["MenuMgmt_ColName"]</th>
                                    <th>@L["MenuMgmt_ColPrice"]</th>
                                    <th>@L["MenuMgmt_ColAvailable"]</th>
                                    <th>@L["MenuMgmt_ColActions"]</th>
                                </tr></thead>
                                <tbody>
                                    @foreach (var item in catGroup.OrderBy(i => i.Name))
                                    {
                                        <tr class="@(item.IsAvailable ? "" : "table-secondary")">
                                            <td>
                                                <strong>@item.Name</strong>
                                                @if (!string.IsNullOrEmpty(item.Description))
                                                {
                                                    <br /><small class="text-muted">@item.Description</small>
                                                }
                                                @if (item.Allergens.Any())
                                                {
                                                    <br />
                                                    @foreach (var a in item.Allergens)
                                                    {
                                                        <span class="badge bg-warning text-dark me-1"
                                                              title="@GetAllergenName(a)">@a.Icon @a.Code</span>
                                                    }
                                                }
                                            </td>
                                            <td class="text-nowrap">@eventCurrencySymbol @((item.PriceInCents / 100.0).ToString("0.00"))</td>
                                            <td>@(item.IsAvailable ? "✓" : "✗")</td>
                                            <td class="text-nowrap">
                                                <button class="btn btn-sm btn-outline-primary me-1"
                                                        @onclick="() => EditItem(item)">@L["MenuMgmt_Edit"]</button>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => ConfirmDeleteAsync(item.Id, item.Name)"
                                                        disabled="@(deletingId == item.Id)">
                                                    @if (deletingId == item.Id) { <span class="spinner-border spinner-border-sm"></span> }
                                                    else { @L["MenuMgmt_Delete"] }
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int EventId { get; set; }

    private string eventName = string.Empty;
    private string eventCurrencySymbol = "€";
    private List<GetEventMenu.MenuItemDto> items = new();
    private List<GetAllergens.AllergenDto> allergens = new();
    private List<GetMenuCategories.CategoryDto> categories = new();
    private bool isLoading = true;
    private bool isSaving;
    private string message = string.Empty;
    private bool messageSuccess;
    private int? editingId;
    private int? deletingId;

    // Category form state
    private int? editingCatId;
    private bool isSavingCat;
    private int? deletingCatId;
    private CatForm catForm = new();

    private ItemForm form = new();

    protected override async Task OnInitializedAsync()
    {
        var eventsResult = await Mediator.QueryAsync(new GetEvents.Query());
        var ev = eventsResult.Events.FirstOrDefault(e => e.Id == EventId);
        eventName = ev?.Name ?? $"Event {EventId}";
        eventCurrencySymbol = ev?.CurrencySymbol ?? "€";

        await Task.WhenAll(LoadCategoriesAsync(), LoadAllergensAsync(), LoadItemsAsync());
    }

    private async Task LoadCategoriesAsync()
    {
        var r = await Mediator.QueryAsync(new GetMenuCategories.Query());
        categories = r.Categories;
    }

    private async Task LoadAllergensAsync()
    {
        var r = await Mediator.QueryAsync(new GetAllergens.Query());
        allergens = r.Allergens;
    }

    private async Task LoadItemsAsync()
    {
        isLoading = true;
        var r = await Mediator.QueryAsync(new GetEventMenu.Query(EventId, IncludeUnavailable: true));
        items = r.Items;
        isLoading = false;
    }

    // ─── Item CRUD ───

    private void EditItem(GetEventMenu.MenuItemDto item)
    {
        editingId = item.Id;
        form = new ItemForm
        {
            Name = item.Name,
            Description = item.Description,
            PriceInCents = item.PriceInCents,
            CategoryId = item.CategoryId,
            IsAvailable = item.IsAvailable,
            AllergenIds = item.Allergens.Select(a => a.Id).ToHashSet()
        };
    }

    private void CancelEdit() { editingId = null; form = new ItemForm(); }

    private async Task SaveItemAsync()
    {
        message = string.Empty;
        if (string.IsNullOrWhiteSpace(form.Name)) { ShowError(L["MenuMgmt_NameRequired"]); return; }
        if (form.PriceInCents < 0) { ShowError(L["MenuMgmt_PriceInvalid"]); return; }
        if (form.CategoryId <= 0) { ShowError(L["MenuMgmt_CategoryRequired"]); return; }

        isSaving = true;
        try
        {
            var allergenIds = form.AllergenIds.ToList();
            if (editingId.HasValue)
            {
                var r = await Mediator.SendAsync(new UpdateMenuItem.Command(
                    editingId.Value, form.Name, form.Description, form.PriceInCents,
                    form.CategoryId, allergenIds, form.IsAvailable));
                message = r.Success ? string.Format(L["MenuMgmt_ItemUpdated"], form.Name) : r.Message;
                messageSuccess = r.Success;
            }
            else
            {
                var r = await Mediator.SendAsync(new CreateMenuItem.Command(
                    EventId, form.Name, form.Description, form.PriceInCents,
                    form.CategoryId, allergenIds, form.IsAvailable));
                message = string.Format(L["MenuMgmt_ItemAdded"], r.Name);
                messageSuccess = true;
            }
            if (messageSuccess) { CancelEdit(); await LoadItemsAsync(); }
        }
        catch (Exception ex) { ShowError(string.Format(L["MenuMgmt_Error"], ex.Message)); }
        isSaving = false;
    }

    private async Task ConfirmDeleteAsync(int id, string name)
    {
        deletingId = id;
        message = string.Empty;
        try
        {
            var r = await Mediator.SendAsync(new DeleteMenuItem.Command(id));
            message = r.Success ? string.Format(L["MenuMgmt_ItemDeleted"], name) : r.Message;
            messageSuccess = r.Success;
            if (r.Success) { if (editingId == id) CancelEdit(); await LoadItemsAsync(); }
        }
        catch (Exception ex) { ShowError(string.Format(L["MenuMgmt_Error"], ex.Message)); }
        deletingId = null;
    }

    // ─── Category CRUD ───

    private void EditCategory(GetMenuCategories.CategoryDto c)
    {
        editingCatId = c.Id;
        catForm = new CatForm { Name = c.Name, NameIt = c.NameIt, DisplayOrder = c.DisplayOrder };
    }

    private void CancelCatEdit() { editingCatId = null; catForm = new CatForm(); }

    private async Task SaveCategoryAsync()
    {
        message = string.Empty;
        if (string.IsNullOrWhiteSpace(catForm.Name) || string.IsNullOrWhiteSpace(catForm.NameIt))
        {
            ShowError(L["MenuMgmt_CatNameRequired"]);
            return;
        }
        isSavingCat = true;
        try
        {
            if (editingCatId.HasValue)
            {
                var r = await Mediator.SendAsync(new UpdateMenuCategory.Command(
                    editingCatId.Value, catForm.Name, catForm.NameIt, catForm.DisplayOrder));
                message = r.Success ? string.Format(L["MenuMgmt_CatUpdated"], catForm.Name) : r.Message;
                messageSuccess = r.Success;
            }
            else
            {
                var r = await Mediator.SendAsync(new CreateMenuCategory.Command(
                    catForm.Name, catForm.NameIt, catForm.DisplayOrder));
                message = string.Format(L["MenuMgmt_CatAdded"], r.Name);
                messageSuccess = true;
            }
            if (messageSuccess) { CancelCatEdit(); await LoadCategoriesAsync(); }
        }
        catch (Exception ex) { ShowError(string.Format(L["MenuMgmt_Error"], ex.Message)); }
        isSavingCat = false;
    }

    private async Task DeleteCategoryAsync(int id)
    {
        deletingCatId = id;
        message = string.Empty;
        try
        {
            var r = await Mediator.SendAsync(new DeleteMenuCategory.Command(id));
            message = r.Success ? L["MenuMgmt_CatDeleted"] : r.Message;
            messageSuccess = r.Success;
            if (r.Success) { if (editingCatId == id) CancelCatEdit(); await LoadCategoriesAsync(); }
        }
        catch (Exception ex) { ShowError(string.Format(L["MenuMgmt_Error"], ex.Message)); }
        deletingCatId = null;
    }

    // ─── Helpers ───

    private void ToggleAllergen(int id, bool add)
    {
        if (add) form.AllergenIds.Add(id);
        else form.AllergenIds.Remove(id);
    }

    private void ShowError(string msg) { message = msg; messageSuccess = false; }

    private static int ToCents(string? input)
    {
        if (decimal.TryParse(input,
                System.Globalization.NumberStyles.AllowDecimalPoint | System.Globalization.NumberStyles.AllowLeadingSign,
                System.Globalization.CultureInfo.InvariantCulture, out var val))
            return (int)Math.Round(val * 100);
        return 0;
    }

    private string GetAllergenName(GetAllergens.AllergenDto a)
    {
        var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        return lang == "it" ? a.NameIt : a.Name;
    }

    private string GetAllergenName(GetEventMenu.AllergenDto a)
    {
        var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        return lang == "it" ? a.NameIt : a.Name;
    }

    private string GetCategoryName(GetMenuCategories.CategoryDto c)
    {
        var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        return lang == "it" ? c.NameIt : c.Name;
    }

    private class ItemForm
    {
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public int PriceInCents { get; set; } = 0;
        public int CategoryId { get; set; } = 0;
        public bool IsAvailable { get; set; } = true;
        public HashSet<int> AllergenIds { get; set; } = new();
    }

    private class CatForm
    {
        public string Name { get; set; } = string.Empty;
        public string NameIt { get; set; } = string.Empty;
        public int DisplayOrder { get; set; } = 0;
    }
}

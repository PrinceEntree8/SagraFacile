@page "/events/{EventId:int}/menu"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["MenuMgmt_PageTitle"]</PageTitle>

<h1>🍽️ @L["MenuMgmt_Heading"] - @eventName</h1>
<a href="/events" class="btn btn-outline-secondary btn-sm mb-3">← @L["MenuMgmt_BackToEvents"]</a>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(messageSuccess ? "alert-success" : "alert-danger") alert-dismissible">
        @message
        <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
    </div>
}

<div class="row">
    <div class="col-lg-5">
        <div class="card mb-4">
            <div class="card-header @(editingId.HasValue ? "bg-warning text-dark" : "bg-primary text-white")">
                <h5 class="mb-0">@(editingId.HasValue ? L["MenuMgmt_EditItem"] : L["MenuMgmt_NewItem"])</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">@L["MenuMgmt_ItemName"] *</label>
                    <input class="form-control" @bind="form.Name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">@L["MenuMgmt_ItemDescription"]</label>
                    <textarea class="form-control" rows="2" @bind="form.Description"></textarea>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">@L["MenuMgmt_ItemPrice"] *</label>
                        <input type="number" min="0" step="0.01" class="form-control" @bind="form.Price" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">@L["MenuMgmt_ItemCategory"] *</label>
                        <select class="form-select" @bind="form.Category">
                            @foreach (MenuCategory cat in Enum.GetValues<MenuCategory>())
                            {
                                <option value="@((int)cat)">@L[$"MenuCategory_{cat}"]</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">@L["MenuMgmt_ItemAllergens"]</label>
                    <div class="border rounded p-2" style="max-height:160px;overflow-y:auto;">
                        @foreach (var a in allergens)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="allergen_@a.Id"
                                       checked="@form.AllergenIds.Contains(a.Id)"
                                       @onchange="e => ToggleAllergen(a.Id, (bool)e.Value!)" />
                                <label class="form-check-label" for="allergen_@a.Id">@GetAllergenName(a)</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="mb-3 form-check">
                    <input class="form-check-input" type="checkbox" id="chkAvailable" @bind="form.IsAvailable" />
                    <label class="form-check-label" for="chkAvailable">@L["MenuMgmt_ItemAvailable"]</label>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn @(editingId.HasValue ? "btn-warning" : "btn-primary")" @onclick="SaveItemAsync" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(editingId.HasValue ? L["MenuMgmt_SaveChanges"] : L["MenuMgmt_AddItem"])
                    </button>
                    @if (editingId.HasValue)
                    {
                        <button class="btn btn-outline-secondary" @onclick="CancelEdit">@L["MenuMgmt_Cancel"]</button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">@L["MenuMgmt_AllItems"]</h5>
            </div>
            <div class="card-body">
                @if (isLoading)
                {
                    <p><em>@L["MenuMgmt_Loading"]</em></p>
                }
                else if (!items.Any())
                {
                    <p class="text-muted">@L["MenuMgmt_NoItems"]</p>
                }
                else
                {
                    @foreach (var cat in Enum.GetValues<MenuCategory>())
                    {
                        var catItems = items.Where(i => i.Category == cat).ToList();
                        if (!catItems.Any()) continue;
                        <h6 class="mt-3 text-uppercase text-muted">@L[$"MenuCategory_{cat}"]</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead><tr>
                                    <th>@L["MenuMgmt_ColName"]</th>
                                    <th>@L["MenuMgmt_ColPrice"]</th>
                                    <th>@L["MenuMgmt_ColAvailable"]</th>
                                    <th>@L["MenuMgmt_ColActions"]</th>
                                </tr></thead>
                                <tbody>
                                    @foreach (var item in catItems)
                                    {
                                        <tr class="@(item.IsAvailable ? "" : "table-secondary")">
                                            <td>
                                                <strong>@item.Name</strong>
                                                @if (!string.IsNullOrEmpty(item.Description))
                                                { <br /><small class="text-muted">@item.Description</small> }
                                                @if (item.Allergens.Any())
                                                {
                                                    <br />
                                                    @foreach (var a in item.Allergens)
                                                    {
                                                        <span class="badge bg-warning text-dark me-1" title="@GetAllergenName(a)">@a.Code</span>
                                                    }
                                                }
                                            </td>
                                            <td class="text-nowrap">@eventCurrencySymbol @item.Price.ToString("0.00")</td>
                                            <td>@(item.IsAvailable ? "✓" : "✗")</td>
                                            <td class="text-nowrap">
                                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditItem(item)">@L["MenuMgmt_Edit"]</button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDeleteAsync(item.Id, item.Name)" disabled="@(deletingId == item.Id)">
                                                    @if (deletingId == item.Id) { <span class="spinner-border spinner-border-sm"></span> }
                                                    else { @L["MenuMgmt_Delete"] }
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int EventId { get; set; }

    private string eventName = string.Empty;
    private string eventCurrencySymbol = "€";
    private List<GetEventMenu.MenuItemDto> items = new();
    private List<GetAllergens.AllergenDto> allergens = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private string message = string.Empty;
    private bool messageSuccess;
    private int? editingId;
    private int? deletingId;

    private ItemForm form = new();

    protected override async Task OnInitializedAsync()
    {
        var eventsResult = await Mediator.QueryAsync(new GetEvents.Query());
        var ev = eventsResult.Events.FirstOrDefault(e => e.Id == EventId);
        eventName = ev?.Name ?? $"Event {EventId}";
        eventCurrencySymbol = ev?.CurrencySymbol ?? "€";

        var allergenResult = await Mediator.QueryAsync(new GetAllergens.Query());
        allergens = allergenResult.Allergens;

        await LoadItemsAsync();
    }

    private async Task LoadItemsAsync()
    {
        isLoading = true;
        var result = await Mediator.QueryAsync(new GetEventMenu.Query(EventId, IncludeUnavailable: true));
        items = result.Items;
        isLoading = false;
    }

    private void EditItem(GetEventMenu.MenuItemDto item)
    {
        editingId = item.Id;
        form = new ItemForm
        {
            Name = item.Name,
            Description = item.Description,
            Price = item.Price,
            Category = (int)item.Category,
            IsAvailable = item.IsAvailable,
            AllergenIds = item.Allergens.Select(a => a.Id).ToHashSet()
        };
    }

    private void CancelEdit()
    {
        editingId = null;
        form = new ItemForm();
    }

    private async Task SaveItemAsync()
    {
        if (string.IsNullOrWhiteSpace(form.Name))
        {
            message = L["MenuMgmt_NameRequired"];
            messageSuccess = false;
            return;
        }
        if (form.Price < 0)
        {
            message = L["MenuMgmt_PriceInvalid"];
            messageSuccess = false;
            return;
        }
        isSaving = true;
        message = string.Empty;
        try
        {
            var allergenIds = form.AllergenIds.ToList();
            if (editingId.HasValue)
            {
                var result = await Mediator.SendAsync(new UpdateMenuItem.Command(
                    editingId.Value, form.Name, form.Description, form.Price,
                    (MenuCategory)form.Category, allergenIds, form.IsAvailable));
                message = result.Success ? string.Format(L["MenuMgmt_ItemUpdated"], form.Name) : result.Message;
                messageSuccess = result.Success;
            }
            else
            {
                var result = await Mediator.SendAsync(new CreateMenuItem.Command(
                    EventId, form.Name, form.Description, form.Price,
                    (MenuCategory)form.Category, allergenIds, form.IsAvailable));
                message = string.Format(L["MenuMgmt_ItemAdded"], result.Name);
                messageSuccess = true;
            }
            if (messageSuccess)
            {
                editingId = null;
                form = new ItemForm();
                await LoadItemsAsync();
            }
        }
        catch (Exception ex)
        {
            message = string.Format(L["MenuMgmt_Error"], ex.Message);
            messageSuccess = false;
        }
        isSaving = false;
    }

    private async Task ConfirmDeleteAsync(int id, string name)
    {
        deletingId = id;
        message = string.Empty;
        try
        {
            var result = await Mediator.SendAsync(new DeleteMenuItem.Command(id));
            message = result.Success ? string.Format(L["MenuMgmt_ItemDeleted"], name) : result.Message;
            messageSuccess = result.Success;
            if (result.Success)
            {
                if (editingId == id) CancelEdit();
                await LoadItemsAsync();
            }
        }
        catch (Exception ex)
        {
            message = string.Format(L["MenuMgmt_Error"], ex.Message);
            messageSuccess = false;
        }
        deletingId = null;
    }

    private void ToggleAllergen(int id, bool add)
    {
        if (add) form.AllergenIds.Add(id);
        else form.AllergenIds.Remove(id);
    }

    private string GetAllergenName(GetAllergens.AllergenDto a)
    {
        var culture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        return culture == "it" ? a.NameIt : a.Name;
    }

    private string GetAllergenName(GetEventMenu.AllergenDto a)
    {
        var culture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        return culture == "it" ? a.NameIt : a.Name;
    }

    private class ItemForm
    {
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public decimal Price { get; set; } = 0;
        public int Category { get; set; } = 0;
        public bool IsAvailable { get; set; } = true;
        public HashSet<int> AllergenIds { get; set; } = new();
    }
}

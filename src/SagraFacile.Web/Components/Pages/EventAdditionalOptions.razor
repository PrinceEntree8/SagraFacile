@page "/events/{EventId:int}/options"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IMediator Mediator
@inject IStringLocalizer<SharedResource> L

@using SagraFacile.Application.Features.Events

<PageTitle>@string.Format(L["EventOptions_PageTitle"], eventName)</PageTitle>

<div class="mb-3">
    <a href="/events" class="btn btn-outline-secondary btn-sm">@L["EventOptions_BackToEvents"]</a>
</div>

<h1>@L["EventOptions_Heading"]</h1>
@if (!string.IsNullOrEmpty(eventName))
{
    <p class="text-muted">@eventName</p>
}

@if (isLoading)
{
    <p><em>@L["EventOptions_Loading"]</em></p>
}
else if (notFound)
{
    <div class="alert alert-warning">@L["EventOptions_EventNotFound"]</div>
}
else
{
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(saveSuccess ? "alert-success" : "alert-danger")">@statusMessage</div>
    }

    <div class="row">
        <div class="col-md-7">

            <!-- Reservation Options -->
            <div class="card mb-4">
                <div class="card-header">
                    <h4 class="mb-0">@L["EventOptions_ReservationOptions"]</h4>
                </div>
                <div class="card-body">

                    <!-- Party Completion -->
                    <h5>@L["EventOptions_PartyCompletion"]</h5>
                    <p class="text-muted small">@L["EventOptions_PartyCompletionDesc"]</p>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="partyCompletionEnabled"
                               @bind="model.PartyCompletionEnabled" />
                        <label class="form-check-label" for="partyCompletionEnabled">
                            @L["EventOptions_EnablePartyCompletion"]
                        </label>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="minPartySize">@L["EventOptions_MinPartySize"]</label>
                        <input type="number" class="form-control" id="minPartySize" min="1"
                               @bind="model.MinPartySize" style="max-width: 120px;" />
                        <div class="form-text">@L["EventOptions_MinPartySizeDesc"]</div>
                    </div>

                </div>
            </div>

            <!-- Future option groups can be added here as additional cards -->

            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@isSaving">
                @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                @L["EventOptions_Save"]
            </button>

        </div>
    </div>
}

@code {
    [Parameter] public int EventId { get; set; }

    private string eventName = string.Empty;
    private bool isLoading = true;
    private bool notFound = false;
    private bool isSaving = false;
    private string statusMessage = string.Empty;
    private bool saveSuccess = false;

    private OptionsModel model = new();

    protected override async Task OnInitializedAsync()
    {
        var result = await Mediator.QueryAsync(new GetEventAdditionalOptions.Query(EventId));
        if (result is null)
        {
            notFound = true;
        }
        else
        {
            model.PartyCompletionEnabled = result.AdditionalOptions.Reservations.PartyCompletion.Enabled;
            model.MinPartySize = result.AdditionalOptions.Reservations.PartyCompletion.MinPartySize;

            var events = await Mediator.QueryAsync(new GetEvents.Query());
            eventName = events.Events.FirstOrDefault(e => e.Id == EventId)?.Name ?? string.Empty;
        }
        isLoading = false;
    }

    private async Task SaveAsync()
    {
        statusMessage = string.Empty;

        if (model.MinPartySize < 1)
        {
            statusMessage = L["EventOptions_MinPartySizeInvalid"];
            saveSuccess = false;
            return;
        }

        isSaving = true;
        try
        {
            var result = await Mediator.SendAsync(new UpdateEventAdditionalOptions.Command(
                EventId,
                model.PartyCompletionEnabled,
                model.MinPartySize));

            if (result.Success)
            {
                statusMessage = L["EventOptions_Saved"];
                saveSuccess = true;
            }
            else
            {
                statusMessage = string.Format(L["EventOptions_Error"], result.Error);
                saveSuccess = false;
            }
        }
        catch (Exception ex)
        {
            statusMessage = string.Format(L["EventOptions_Error"], ex.Message);
            saveSuccess = false;
        }
        isSaving = false;
    }

    private class OptionsModel
    {
        public bool PartyCompletionEnabled { get; set; } = false;
        public int MinPartySize { get; set; } = 8;
    }
}

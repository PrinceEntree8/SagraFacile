@page "/receptionist"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@implements IAsyncDisposable

<PageTitle>@L["Receptionist_PageTitle"]</PageTitle>

<h1>@L["Receptionist_Heading"]</h1>

<div class="row">
    <div class="col-md-5">
        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h3 class="mb-0">@L["Receptionist_AvailableSeats"]</h3>
            </div>
            <div class="card-body text-center">
                <h1 class="display-1">@availableSeats</h1>
                <p class="text-muted">@L["Receptionist_AnnouncedBy"]</p>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h3>@L["Receptionist_NewReservation"]</h3>
            </div>
            <div class="card-body">
                <EditForm Model="@newReservation" OnValidSubmit="@CreateReservation">
                    <div class="mb-3">
                        <label class="form-label">@L["Receptionist_CustomerName"]</label>
                        <InputText @bind-Value="newReservation.CustomerName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@L["Receptionist_PartySize"]</label>
                        <InputNumber @bind-Value="newReservation.PartySize" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@L["Receptionist_Notes"]</label>
                        <InputTextArea @bind-Value="newReservation.Notes" class="form-control" rows="3" />
                        <small class="form-text text-muted">@L["Receptionist_NotesHint"]</small>
                    </div>

                    <button type="submit" class="btn btn-primary" disabled="@(isCreating || actionInProgress != null)">
                        @if (isCreating)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @L["Receptionist_Submit"]
                    </button>
                </EditForm>

                @if (!string.IsNullOrEmpty(creationMessage))
                {
                    <div class="alert alert-success mt-3">@creationMessage</div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3>@L["Receptionist_ActiveReservations"]</h3>
                <div>
                    <button class="btn btn-sm btn-outline-primary" @onclick="@(() => LoadReservations("Waiting"))">@L["Receptionist_FilterWaiting"]</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => LoadReservations("Called"))">@L["Receptionist_FilterCalled"]</button>
                    <button class="btn btn-sm btn-outline-info" @onclick="@(() => LoadReservations(null))">@L["Receptionist_FilterAll"]</button>
                </div>
            </div>
            <div class="card-body">
                @if (isLoading)
                {
                    <p><em>@L["Receptionist_LoadingReservations"]</em></p>
                }
                else if (reservations != null && reservations.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>@L["Receptionist_ColQueue"]</th>
                                    <th>@L["Receptionist_ColName"]</th>
                                    <th>@L["Receptionist_ColParty"]</th>
                                    <th>@L["Receptionist_ColStatus"]</th>
                                    <th>@L["Receptionist_ColWaiting"]</th>
                                    <th>@L["Receptionist_ColCalls"]</th>
                                    <th>@L["Receptionist_ColActions"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var reservation in reservations)
                                {
                                    <tr class="@GetRowClass(reservation)">
                                        <td><strong>@reservation.QueueNumber</strong></td>
                                        <td>@reservation.CustomerName</td>
                                        <td>
                                            <span class="badge bg-info">@reservation.PartySize</span>
                                        </td>
                                        <td><span class="badge @GetStatusBadge(reservation.Status)">@reservation.Status</span></td>
                                        <td>
                                            @FormatTimeSpan(reservation.WaitingTime)
                                            @if (reservation.TimeSinceLastCall.HasValue)
                                            {
                                                <br /><small class="text-muted">@string.Format(L["Receptionist_LastCall"], FormatTimeSpan(reservation.TimeSinceLastCall.Value))</small>
                                            }
                                        </td>
                                        <td>@reservation.CallCount</td>
                                        <td>
                                            @if (reservation.Status == "Waiting" || reservation.Status == "Called")
                                            {
                                                <button class="btn btn-sm btn-success me-1" @onclick="@(() => CallReservationAsync(reservation.Id))" disabled="@(actionInProgress == reservation.Id)">
                                                    @L["Receptionist_ActionCall"]
                                                </button>
                                                <button class="btn btn-sm btn-danger" @onclick="@(() => VoidReservationAsync(reservation.Id))" disabled="@(actionInProgress == reservation.Id)">
                                                    @L["Receptionist_ActionVoid"]
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="mt-3">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="card text-center">
                                    <div class="card-body">
                                        <h6 class="card-subtitle mb-2 text-muted">@L["Receptionist_ToBeSeated"]</h6>
                                        <h4 class="card-title">@string.Format(L["Receptionist_Reservations"], toBeSeatedCount)</h4>
                                        <p class="text-muted">@string.Format(L["Receptionist_People"], toBeSeatedPeople)</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card text-center">
                                    <div class="card-body">
                                        <h6 class="card-subtitle mb-2 text-muted">@L["Receptionist_Served"]</h6>
                                        <h4 class="card-title">@string.Format(L["Receptionist_Reservations"], seatedCount)</h4>
                                        <p class="text-muted">@string.Format(L["Receptionist_People"], seatedPeople)</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card text-center bg-light">
                                    <div class="card-body">
                                        <h6 class="card-subtitle mb-2 text-muted">@L["Receptionist_Total"]</h6>
                                        <h4 class="card-title">@string.Format(L["Receptionist_Reservations"], totalCount)</h4>
                                        <p class="text-muted">@string.Format(L["Receptionist_People"], totalPeople)</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <p><em>@L["Receptionist_NoReservations"]</em></p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private HubConnection? hubConnection;
    private NewReservationModel newReservation = new();
    private List<GetReservations.ReservationDto> reservations = new();
    private int totalCount = 0;
    private int totalPeople = 0;
    private int toBeSeatedCount = 0;
    private int toBeSeatedPeople = 0;
    private int seatedCount = 0;
    private int seatedPeople = 0;
    private int availableSeats = 0;
    private bool isLoading = true;
    private bool isCreating = false;
    private string creationMessage = string.Empty;
    private int? actionInProgress = null;
    private string? currentFilter = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadReservations(null);
        await InitializeSignalR();
    }

    private async Task InitializeSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/reservations"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<int, string, string, int>("ReservationCreated", async (id, queueNumber, name, size) =>
        {
            await LoadReservations(currentFilter);
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string, string, int, int>("ReservationCalled", async (id, queueNumber, customerName, partySize, callCount) =>
        {
            await LoadReservations(currentFilter);
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string>("ReservationVoided", async (id, queueNumber) =>
        {
            await LoadReservations(currentFilter);
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int, string>("ReservationSeated", async (id, queueNumber) =>
        {
            await LoadReservations(currentFilter);
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int>("AvailableSeatsUpdated", async (seats) =>
        {
            availableSeats = seats;
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
    }

    private async Task LoadReservations(string? status)
    {
        isLoading = true;
        currentFilter = status;
        try
        {
            var query = new GetReservations.Query(Status: status, Page: 1, PageSize: 100);
            var result = await Mediator.Send(query, CancellationToken.None);
            reservations = result.Reservations;
            totalCount = result.TotalCount;
            totalPeople = reservations.Sum(r => r.PartySize);
            
            // Calculate breakdown by status
            var toBeSeated = reservations.Where(r => r.Status == "Waiting" || r.Status == "Called").ToList();
            toBeSeatedCount = toBeSeated.Count;
            toBeSeatedPeople = toBeSeated.Sum(r => r.PartySize);
            
            var seated = reservations.Where(r => r.Status == "Seated").ToList();
            seatedCount = seated.Count;
            seatedPeople = seated.Sum(r => r.PartySize);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateReservation()
    {
        isCreating = true;
        creationMessage = string.Empty;

        try
        {
            var command = new CreateReservation.Command(
                newReservation.CustomerName,
                newReservation.PartySize,
                newReservation.Notes
            );

            var result = await Mediator.Send(command, CancellationToken.None);
            
            creationMessage = string.Format(L["Receptionist_ReservationCreated"], result.QueueNumber);
            newReservation = new();
            
            // Notify via SignalR
            if (hubConnection?.State == HubConnectionState.Connected)
            {
                await hubConnection.SendAsync("NotifyReservationCreated", result.Id, result.QueueNumber, command.CustomerName, command.PartySize);
            }
            
            await LoadReservations(currentFilter);
        }
        catch (Exception ex)
        {
            creationMessage = string.Format(L["Receptionist_Error"], ex.Message);
        }
        finally
        {
            isCreating = false;
        }
    }

    private async Task CallReservationAsync(int reservationId)
    {
        actionInProgress = reservationId;
        try
        {
            var command = new CallReservation.Command(reservationId, "Receptionist");
            var result = await Mediator.Send(command, CancellationToken.None);
            
            if (result.Success)
            {
                var reservation = reservations.FirstOrDefault(r => r.Id == reservationId);
                if (reservation != null && hubConnection?.State == HubConnectionState.Connected)
                {
                    await hubConnection.SendAsync("NotifyReservationCalled", reservationId, reservation.QueueNumber, reservation.CustomerName, reservation.PartySize, reservation.CallCount + 1);
                }
            }
            
            await LoadReservations(currentFilter);
        }
        finally
        {
            actionInProgress = null;
        }
    }

    private async Task SeatReservationAsync(int reservationId)
    {
        actionInProgress = reservationId;
        try
        {
            var command = new SeatReservation.Command(reservationId);
            var result = await Mediator.Send(command, CancellationToken.None);
            
            if (result.Success)
            {
                var reservation = reservations.FirstOrDefault(r => r.Id == reservationId);
                if (reservation != null && hubConnection?.State == HubConnectionState.Connected)
                {
                    await hubConnection.SendAsync("NotifyReservationSeated", reservationId, reservation.QueueNumber);
                }
            }
            
            await LoadReservations(currentFilter);
        }
        finally
        {
            actionInProgress = null;
        }
    }

    private async Task VoidReservationAsync(int reservationId)
    {
        actionInProgress = reservationId;
        try
        {
            var command = new VoidReservation.Command(reservationId);
            var result = await Mediator.Send(command, CancellationToken.None);
            
            if (result.Success)
            {
                var reservation = reservations.FirstOrDefault(r => r.Id == reservationId);
                if (reservation != null && hubConnection?.State == HubConnectionState.Connected)
                {
                    await hubConnection.SendAsync("NotifyReservationVoided", reservationId, reservation.QueueNumber);
                }
            }
            
            await LoadReservations(currentFilter);
        }
        finally
        {
            actionInProgress = null;
        }
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Waiting" => "bg-warning",
        "Called" => "bg-info",
        "Seated" => "bg-success",
        "Voided" => "bg-secondary",
        _ => "bg-secondary"
    };

    private string GetRowClass(GetReservations.ReservationDto reservation)
    {
        if (reservation.WaitingTime.TotalMinutes > 30)
            return "table-danger";
        return "";
    }

    private string FormatTimeSpan(TimeSpan timeSpan)
    {
        if (timeSpan.TotalHours >= 1)
            return $"{(int)timeSpan.TotalHours}h {timeSpan.Minutes}m";
        return $"{(int)timeSpan.TotalMinutes}m";
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private class NewReservationModel
    {
        public string CustomerName { get; set; } = string.Empty;
        public int PartySize { get; set; } = 2;
        public string Notes { get; set; } = string.Empty;
    }
}

@page "/menu"
@*@layout DisplayLayout*@
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@implements IAsyncDisposable

<PageTitle>@L["PublicMenu_PageTitle"]</PageTitle>

<div class="container py-4">
    @if (isLoading)
    {
        <p class="text-center"><em>@L["PublicMenu_Loading"]</em></p>
    }
    else if (activeEvent is null)
    {
        <div class="text-center text-muted mt-5">
            <h2>@L["PublicMenu_NoActiveEvent"]</h2>
        </div>
    }
    else
    {
        <div class="text-center mb-4">
            <h1>🍽️ @activeEvent.Name</h1>
        </div>

        <div class="text-center mb-4">
            <a class="btn btn-outline-primary btn-lg" href="/now-calling">
                @L["PublicMenu_GoToNowCalling"]
            </a>
        </div>

        <section class="card mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">@L["PublicMenu_LatestCalled"]</h2>
                @if (initialLoadFailed)
                {
                    <div class="alert alert-warning mb-3" role="alert">
                        @L["NowCalling_LoadWarning"]
                    </div>
                }
                @if (latestCalled is null)
                {
                    <p class="text-muted mb-0">@L["PublicMenu_NoCalledYet"]</p>
                }
                else
                {
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="badge bg-primary fs-6">#@latestCalled.SequenceNumber</span>
                        <span class="fw-semibold">@latestCalled.CustomerName</span>
                        <span class="text-muted"><i class="bi bi-people"></i> @latestCalled.PartySize</span>
                    </div>
                }
            </div>
        </section>
        
        @if (!string.IsNullOrWhiteSpace(menuDetails?.WarningMessage))
        {
            <div class="alert alert-warning">@((MarkupString)menuDetails.WarningMessage)</div>
        }
        @if (!string.IsNullOrWhiteSpace(menuDetails?.Header))
        {
            <div class="menu-header mb-4">@((MarkupString)menuDetails.Header)</div>
        }

        @if (!items.Any())
        {
            <p class="text-center text-muted">@L["PublicMenu_NoItems"]</p>
        }
        else
        {
            @foreach (var catGroup in items
                .GroupBy(i => new { i.CategoryId, i.CategoryName })
                .OrderBy(g => categories.FirstOrDefault(c => c.Id == g.Key.CategoryId)?.DisplayOrder ?? 999))
            {
                <section class="mb-5">
                    <h2 class="border-bottom pb-2">@catGroup.Key.CategoryName</h2>
                    <div class="row row-cols-1 row-cols-md-2 g-3 mt-1">
                        @foreach (var item in catGroup.OrderBy(i => i.Name))
                        {
                            <div class="col">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <h5 class="card-title mb-1">@item.Name</h5>
                                            <span class="badge bg-primary fs-6 ms-2">
                                                @activeEvent.CurrencySymbol @((item.PriceInCents / 100.0).ToString("0.00"))
                                            </span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            <p class="card-text text-muted small mb-2">@item.Description</p>
                                        }
                                        @if (item.Allergens.Any())
                                        {
                                            <div>
                                                <small class="text-muted">@L["PublicMenu_Allergens"]: </small>
                                                @foreach (var a in item.Allergens)
                                                {
                                                    <span class="badge bg-warning text-dark me-1" title="@L[$"Allergen_{a.Code}"]">
                                                        @a.Icon @a.Code
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }
        }
        @if (!string.IsNullOrWhiteSpace(menuDetails?.Footer))
        {
            <div class="menu-footer mt-4">@((MarkupString)menuDetails.Footer)</div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private GetActiveEvent.EventDto? activeEvent;
    private List<GetEventMenu.MenuItemDto> items = new();
    private List<GetMenuCategories.CategoryDto> categories = new();
    private GetMenuDetails.MenuDetailsDto? menuDetails;
    private CalledEntry? latestCalled;
    private HubConnection? hubConnection;
    private bool initialLoadFailed;
    private const string CalledStatus = "Called";

    protected override async Task OnInitializedAsync()
    {
        var activeResult = await Mediator.QueryAsync(new GetActiveEvent.Query());
        activeEvent = activeResult.ActiveEvent;
        if (activeEvent is not null)
        {
            var catTask = Mediator.QueryAsync(new GetMenuCategories.Query());
            var menuTask = Mediator.QueryAsync(new GetEventMenu.Query(activeEvent.Id, IncludeUnavailable: false));
            var detailsTask = Mediator.QueryAsync(new GetMenuDetails.Query(activeEvent.Id));
            var latestCalledTask = LoadLatestCalledAsync(activeEvent.Id);
            await Task.WhenAll(catTask, menuTask, detailsTask, latestCalledTask);
            categories = (await catTask).Categories;
            items = (await menuTask).Items;
            menuDetails = (await detailsTask).Details;
            await InitializeSignalRAsync();
        }
        isLoading = false;
    }

    private async Task LoadLatestCalledAsync(int eventId)
    {
        try
        {
            var result = await Mediator.QueryAsync(new GetReservations.Query(EventId: eventId, Status: CalledStatus, Page: 1, PageSize: 10));
            var latest = result.Reservations
                .Where(r => r.LastCalledAt.HasValue)
                .OrderByDescending(r => r.LastCalledAt!.Value)
                .FirstOrDefault();

            latestCalled = latest is null
                ? null
                : new CalledEntry(latest.Id, latest.SequenceNumber, latest.CustomerName, latest.PartySize);
        }
        catch
        {
            initialLoadFailed = true;
        }
    }

    private async Task InitializeSignalRAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/reservations"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<int, int, string, int, int>(
            "ReservationCalled",
            async (id, sequenceNumber, customerName, partySize, _) =>
            {
                latestCalled = new CalledEntry(id, sequenceNumber, customerName, partySize);
                await InvokeAsync(StateHasChanged);
            });

        hubConnection.On<int, int>("ReservationVoided", async (id, _) =>
        {
            if (activeEvent is not null && latestCalled?.Id == id)
            {
                await LoadLatestCalledAsync(activeEvent.Id);
                await InvokeAsync(StateHasChanged);
            }
        });

        hubConnection.On<int, int>("ReservationSeated", async (id, _) =>
        {
            if (activeEvent is not null && latestCalled?.Id == id)
            {
                await LoadLatestCalledAsync(activeEvent.Id);
                await InvokeAsync(StateHasChanged);
            }
        });

        try
        {
            await hubConnection.StartAsync();
            if (hubConnection.State == HubConnectionState.Connected)
            {
                await hubConnection.SendAsync("JoinReservationGroup", "NOW_CALLING");
            }
        }
        catch
        {
            // No-op: page still works with initial snapshot if connection fails.
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private record CalledEntry(int Id, int SequenceNumber, string CustomerName, int PartySize);
}

@page "/menu"
@rendermode InteractiveServer
@inject IMediator Mediator
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["PublicMenu_PageTitle"]</PageTitle>

<div class="container py-4">
    @if (isLoading)
    {
        <p class="text-center"><em>@L["PublicMenu_Loading"]</em></p>
    }
    else if (activeEvent is null)
    {
        <div class="text-center text-muted mt-5">
            <h2>🍽️ @L["PublicMenu_NoActiveEvent"]</h2>
        </div>
    }
    else
    {
        <div class="text-center mb-4">
            <h1>🍽️ @activeEvent.Name</h1>
        </div>

        @if (!items.Any())
        {
            <p class="text-center text-muted">@L["PublicMenu_NoItems"]</p>
        }
        else
        {
            @foreach (var catGroup in items
                .GroupBy(i => new { i.CategoryId, i.CategoryName })
                .OrderBy(g => categories.FirstOrDefault(c => c.Id == g.Key.CategoryId)?.DisplayOrder ?? 999))
            {
                <section class="mb-5">
                    <h2 class="border-bottom pb-2">@catGroup.Key.CategoryName</h2>
                    <div class="row row-cols-1 row-cols-md-2 g-3 mt-1">
                        @foreach (var item in catGroup.OrderBy(i => i.Name))
                        {
                            <div class="col">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <h5 class="card-title mb-1">@item.Name</h5>
                                            <span class="badge bg-primary fs-6 ms-2">
                                                @activeEvent.CurrencySymbol @((item.PriceInCents / 100.0).ToString("0.00"))
                                            </span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            <p class="card-text text-muted small mb-2">@item.Description</p>
                                        }
                                        @if (item.Allergens.Any())
                                        {
                                            <div>
                                                <small class="text-muted">@L["PublicMenu_Allergens"]: </small>
                                                @foreach (var a in item.Allergens)
                                                {
                                                    <span class="badge bg-warning text-dark me-1" title="@L[$"Allergen_{a.Code}"]">
                                                        @a.Icon @a.Code
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }
        }
    }
</div>

@code {
    private bool isLoading = true;
    private GetActiveEvent.EventDto? activeEvent;
    private List<GetEventMenu.MenuItemDto> items = new();
    private List<GetMenuCategories.CategoryDto> categories = new();

    protected override async Task OnInitializedAsync()
    {
        var activeResult = await Mediator.QueryAsync(new GetActiveEvent.Query());
        activeEvent = activeResult.ActiveEvent;
        if (activeEvent is not null)
        {
            var catTask = Mediator.QueryAsync(new GetMenuCategories.Query());
            var menuTask = Mediator.QueryAsync(new GetEventMenu.Query(activeEvent.Id, IncludeUnavailable: false));
            await Task.WhenAll(catTask, menuTask);
            categories = catTask.Result.Categories;
            items = menuTask.Result.Items;
        }
        isLoading = false;
    }
}

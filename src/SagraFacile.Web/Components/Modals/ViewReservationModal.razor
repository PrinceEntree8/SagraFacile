@using SagraFacile.Domain.Features.Reservations
@inject IStringLocalizer<SharedResource> L
<div class="modal fade" id="reservationDetailModal" tabindex="-1" aria-hidden="true">

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">@L["ReservationEdit_ModalTitle"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                @if (Reservation is not null)
                {
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>#@Reservation.SequenceNumber</strong>
                        <span class="badge @Reservation.Status">@L["Reservation_Status_" + Reservation.Status]</span>
                    </div>
                    <div class="mb-2">@Reservation.CustomerName</div>
                    <div class="mb-2">
                        <span class="badge bg-secondary"><i class="bi bi-people"></i>@Reservation.PartySize</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Reservation.Notes))
                    {
                        <div class="text-muted">@Reservation.Notes</div>
                    }
                }
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@L["Common_Close"]</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public required GetReservations.ReservationDto? Reservation { get; set; }

}